---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = '/og-default.png',
  noindex = false,
} = Astro.props;

// Format title properly
const siteName = "Arcdome";
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    
    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.url.origin)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(ogImage, Astro.url.origin)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Google AdSense -->
    <meta name="google-adsense-account" content="ca-pub-8903097794149189">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8903097794149189"
     crossorigin="anonymous"></script>
  </head>
  <body>
    <div class="app-container">
      <Header />
      <main id="main-content" class="main-layout">
        <slot />
      </main>
      <Footer />
    </div>
    
    <CookieConsent />
  </body>
</html>

<style is:global>
  /* Design Tokens / CSS Variables */
  :root {
    --bg-base: #f8fafc;
    --bg-surface: #ffffff;
    --bg-surface-solid: #ffffff;
    --bg-footer: #f1f5f9;
    --bg-header: rgba(255, 255, 255, 0.75);
    
    --border-color: #e2e8f0;
    --border-hover: #cbd5e1;
    --primary: #2563eb;
    --primary-hover: #1d4ed8;
    --primary-glow: rgba(37, 99, 235, 0.05);
    --secondary: #475569;
    --secondary-hover: #334155;
    
    --bg-btn-sec: #ffffff;
    --bg-btn-sec-hover: #f8fafc;
    
    --text-main: #0f172a;
    --text-muted: #64748b;
    --text-inverse: #ffffff;
    
    --font-heading: 'Outfit', 'Inter', sans-serif;
    --font-body: 'Inter', sans-serif;
    
    --transition-smooth: all 0.2s ease-in-out;
    --shadow-premium: 0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px 0 rgba(0, 0, 0, 0.03);
    --shadow-card: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    
    --gradient-text: linear-gradient(135deg, #2563eb 0%, #00f2fe 100%);
    --gradient-accent: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
  }

  /* Dark Theme Variable Overrides */
  @media (prefers-color-scheme: dark) {
    :root {
      --bg-base: #0b0f19;
      --bg-surface: rgba(17, 24, 39, 0.60);
      --bg-surface-solid: #111827;
      --bg-footer: #070a13;
      --bg-header: rgba(11, 15, 25, 0.8);
      
      --border-color: rgba(255, 255, 255, 0.08);
      --border-hover: rgba(255, 255, 255, 0.15);
      
      --primary: #38bdf8;
      --primary-hover: #0ea5e9;
      --primary-glow: rgba(56, 189, 248, 0.08);
      
      --bg-btn-sec: rgba(255, 255, 255, 0.05);
      --bg-btn-sec-hover: rgba(255, 255, 255, 0.1);
      
      --text-main: #f3f4f6;
      --text-muted: #9ca3af;
      --text-inverse: #0b0f19;
      
      --gradient-text: linear-gradient(135deg, #38bdf8 0%, #00f2fe 100%);
      --gradient-accent: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
    }
  }

  /* Reset & Core Styles */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    font-family: var(--font-body);
    background-color: var(--bg-base);
    color: var(--text-main);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100%;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  body {
    min-height: 100vh;
    overflow-x: hidden;
  }

  .app-container {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .main-layout {
    flex: 1;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 104px 24px 64px;
    box-sizing: border-box;
  }

  /* Typography */
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--text-main);
  }

  p {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--text-muted);
  }

  a {
    color: var(--primary);
    text-decoration: none;
    transition: var(--transition-smooth);
  }

  a:hover {
    color: var(--primary-hover);
    text-decoration: underline;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.95rem;
    border-radius: 6px;
    border: 1px solid transparent;
    cursor: pointer;
    transition: var(--transition-smooth);
    gap: 8px;
  }

  .btn-primary {
    background: var(--primary);
    color: var(--text-inverse);
  }

  .btn-primary:hover {
    background: var(--primary-hover);
    color: var(--text-inverse);
  }

  .btn-secondary {
    background: var(--bg-btn-sec);
    border: 1px solid var(--border-color);
    color: var(--text-main);
  }

  .btn-secondary:hover {
    background: var(--bg-btn-sec-hover);
    border-color: var(--border-hover);
  }

  /* Solid Cards */
  .glass-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 24px;
    box-shadow: var(--shadow-premium);
    transition: var(--transition-smooth);
  }

  .glass-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-card);
  }

  /* Custom Scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }

  ::-webkit-scrollbar-track {
    background: var(--bg-base);
  }

  ::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }

  /* Section Titles */
  .section-title {
    font-size: 1.85rem;
    font-weight: 700;
    margin-bottom: 10px;
    text-align: center;
    color: var(--text-main);
  }

  .section-subtitle {
    font-size: 1rem;
    color: var(--text-muted);
    text-align: center;
    margin-bottom: 32px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Mobile tools pages overrides */
  @media (max-width: 600px) {
    .tool-page-container .aeo-summary-section {
      display: none !important;
    }
  }
</style>
