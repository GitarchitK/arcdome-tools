---
// SCSS Calculator component
---

<div class="calculator-card glass-card">
  <div class="calculator-layout">
    <!-- Inputs Panel -->
    <div class="calc-inputs">
      <h2 class="calc-title">Senior Citizen Savings Scheme (SCSS) Calculator</h2>
      <p class="calc-subtitle">Estimate your quarterly interest income and maturity value under the Government SCSS scheme.</p>

      <!-- Principal Amount -->
      <div class="input-group">
        <div class="input-header">
          <label for="scss-principal">Total Deposit (₹)</label>
          <input type="number" id="scss-principal-num" min="10000" max="3000000" step="10000" value="1000000" class="num-input font-semibold" />
        </div>
        <input type="range" id="scss-principal" min="10000" max="3000000" step="10000" value="1000000" class="range-slider" />
        <div class="slider-labels">
          <span>₹10K</span>
          <span>₹15L</span>
          <span>₹30L (Max Limit)</span>
        </div>
      </div>

      <!-- Interest Rate -->
      <div class="input-group">
        <div class="input-header">
          <label for="scss-rate">Interest Rate (% p.a.)</label>
          <input type="number" id="scss-rate-num" min="1" max="15" step="0.05" value="8.20" class="num-input" />
        </div>
        <input type="range" id="scss-rate" min="1" max="15" step="0.05" value="8.20" class="range-slider" />
        <div class="slider-labels">
          <span>1%</span>
          <span>8.2% (Current Rate)</span>
          <span>15%</span>
        </div>
      </div>

      <!-- Tenure -->
      <div class="input-group">
        <label for="scss-tenure">Scheme Tenure (Years)</label>
        <select id="scss-tenure" class="select-dropdown w-full">
          <option value="5" selected>5 Years (Standard Tenure)</option>
          <option value="8">8 Years (Extended by 3 Years)</option>
        </select>
      </div>

      <!-- TDS Alert box -->
      <div class="tds-alert-box glass-card alert-hidden" id="scss-tds-alert">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="alert-icon">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
          <line x1="12" y1="9" x2="12" y2="13" />
          <line x1="12" y1="17" x2="12.01" y2="17" />
        </svg>
        <div class="alert-content">
          <strong>Taxation & TDS Alert</strong>
          <span id="scss-tds-text">Annual interest exceeds ₹50,000. TDS of 10% will be applicable.</span>
        </div>
      </div>
    </div>

    <!-- Outputs & Charts Panel -->
    <div class="calc-outputs">
      <div class="outputs-container glass-card">
        <h3>Payout Breakdown</h3>

        <!-- Payout Displays -->
        <div class="payout-row">
          <div class="payout-box highlighted-payout">
            <span class="payout-label">Quarterly Payout</span>
            <span class="payout-val" id="scss-quarterly-val">₹20,500</span>
          </div>
        </div>

        <hr class="calc-divider" />

        <!-- Metrics Grid -->
        <div class="metrics-grid">
          <div class="metric-item">
            <span class="metric-dot principal-dot"></span>
            <div>
              <span class="metric-label">Invested Deposit</span>
              <span class="metric-val" id="scss-invested-val">₹10,00,000</span>
            </div>
          </div>
          <div class="metric-item">
            <span class="metric-dot interest-dot"></span>
            <div>
              <span class="metric-label">Est. Total Interest</span>
              <span class="metric-val text-primary" id="scss-interest-val">₹4,10,000</span>
            </div>
          </div>
        </div>

        <hr class="calc-divider" style="margin-top: 0;" />

        <div class="total-financial-value">
          <span class="val-label">Total Cash Inflow (Principal + Interest)</span>
          <strong id="scss-total-val">₹14,10,000</strong>
        </div>

        <!-- SVG Donut Chart Visual -->
        <div class="chart-container" style="margin-top: 24px;">
          <svg width="180" height="180" viewBox="0 0 180 180" class="donut-chart">
            <circle cx="90" cy="90" r="70" class="chart-bg" stroke-width="16" />
            <circle cx="90" cy="90" r="70" class="chart-fill" id="scss-chart-fill" stroke-width="16" stroke-dasharray="439.8" stroke-dashoffset="130" transform="rotate(-90 90 90)" />
          </svg>
          <div class="chart-label">
            <span id="scss-ratio-pct">29.1%</span>
            <span>Interest</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Comparison Box -->
  <div class="comparison-section">
    <h3 class="comparison-title">SCSS vs. Traditional Savings Methods</h3>
    <p class="comparison-subtitle">Understand how SCSS compares to standard Fixed Deposits and Senior Savings Schemes.</p>
    
    <div class="comparison-table-wrapper">
      <table class="comparison-table">
        <thead>
          <tr>
            <th>Feature</th>
            <th>SCSS (Govt Scheme)</th>
            <th>Bank Fixed Deposit (FD)</th>
            <th>Post Office MIS (POMIS)</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>Interest Rate (approx)</strong></td>
            <td class="text-primary font-bold">8.20% p.a.</td>
            <td>~7.25% - 7.75% p.a.</td>
            <td>~7.40% p.a.</td>
          </tr>
          <tr>
            <td><strong>Payout Frequency</strong></td>
            <td>Quarterly</td>
            <td>Monthly / Quarterly / Maturity</td>
            <td>Monthly</td>
          </tr>
          <tr>
            <td><strong>Max Limit</strong></td>
            <td>₹30 Lakhs</td>
            <td>No Limit</td>
            <td>₹9 Lakhs (Single) / ₹15 Lakhs (Joint)</td>
          </tr>
          <tr>
            <td><strong>Tax Benefits (Sec 80C)</strong></td>
            <td class="text-green-600 font-semibold">Yes (Up to ₹1.5L)</td>
            <td>Only on 5-Year Tax Saver FDs</td>
            <td>No</td>
          </tr>
          <tr>
            <td><strong>Safety</strong></td>
            <td>Sovereign (Govt backed)</td>
            <td>DICGC Covered up to ₹5 Lakhs</td>
            <td>Sovereign (Govt backed)</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  // Elements
  const principalSlider = document.getElementById('scss-principal') as HTMLInputElement;
  const principalNum = document.getElementById('scss-principal-num') as HTMLInputElement;
  const rateSlider = document.getElementById('scss-rate') as HTMLInputElement;
  const rateNum = document.getElementById('scss-rate-num') as HTMLInputElement;
  const tenureSelect = document.getElementById('scss-tenure') as HTMLSelectElement;

  const quarterlyValText = document.getElementById('scss-quarterly-val');
  const investedValText = document.getElementById('scss-invested-val');
  const interestValText = document.getElementById('scss-interest-val');
  const totalValText = document.getElementById('scss-total-val');
  const ratioText = document.getElementById('scss-ratio-pct');
  const chartFillCircle = document.getElementById('scss-chart-fill');
  const tdsAlert = document.getElementById('scss-tds-alert');
  const tdsText = document.getElementById('scss-tds-text');

  // Synchronizers
  function syncInputs(slider: HTMLInputElement, numInput: HTMLInputElement, callback: () => void) {
    slider.addEventListener('input', () => {
      numInput.value = slider.value;
      callback();
    });
    numInput.addEventListener('change', () => {
      let val = parseFloat(numInput.value);
      const min = parseFloat(numInput.min);
      const max = parseFloat(numInput.max);
      if (isNaN(val)) val = min;
      if (val < min) val = min;
      if (val > max) val = max;
      numInput.value = String(val);
      slider.value = String(val);
      callback();
    });
  }

  // Calculate SCSS Payouts
  function calculateSCSS() {
    const P = parseFloat(principalSlider.value);
    const R = parseFloat(rateSlider.value) / 100;
    const years = parseInt(tenureSelect.value);

    const formatCurrency = (val: number) => {
      return '₹' + Math.round(val).toLocaleString('en-IN');
    };

    // Calculate Quarterly Interest: P * R * 1/4
    const quarterlyPayout = P * R * 0.25;
    const annualInterest = quarterlyPayout * 4;
    const totalInterest = annualInterest * years;
    const totalCashValue = P + totalInterest;

    // Update displays
    if (quarterlyValText) quarterlyValText.innerText = formatCurrency(quarterlyPayout);
    if (investedValText) investedValText.innerText = formatCurrency(P);
    if (interestValText) interestValText.innerText = formatCurrency(totalInterest);
    if (totalValText) totalValText.innerText = formatCurrency(totalCashValue);

    // Update TDS Warn box
    // Threshold is ₹50,000 for Senior Citizens
    if (annualInterest > 50000) {
      if (tdsAlert && tdsText) {
        tdsAlert.classList.remove('alert-hidden');
        tdsText.innerHTML = `Your annual interest is <strong>${formatCurrency(annualInterest)}</strong>, which exceeds the ₹50,000 limit. The bank will deduct <strong>TDS at 10%</strong> (₹${Math.round(annualInterest * 0.1).toLocaleString('en-IN')} annually) unless Form 15H is submitted.`;
      }
    } else {
      if (tdsAlert) {
        tdsAlert.classList.add('alert-hidden');
      }
    }

    // Update Donut Chart
    const ratio = totalInterest / totalCashValue;
    const interestPct = ratio * 100;
    if (ratioText) ratioText.innerText = interestPct.toFixed(1) + '%';

    if (chartFillCircle) {
      const maxOffset = 439.8;
      const offset = maxOffset - (interestPct / 100) * maxOffset;
      chartFillCircle.setAttribute('stroke-dashoffset', String(offset));
    }
  }

  // Init
  syncInputs(principalSlider, principalNum, calculateSCSS);
  syncInputs(rateSlider, rateNum, calculateSCSS);
  tenureSelect.addEventListener('change', calculateSCSS);

  calculateSCSS();
</script>

<style>
  /* Base Styles matching FD/RD Calculators */
  .calculator-card {
    padding: 32px;
    background: var(--bg-surface);
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .calculator-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 32px;
    align-items: start;
  }

  @media (max-width: 820px) {
    .calculator-layout {
      grid-template-columns: 1fr;
    }
    .calculator-card {
      padding: 20px;
    }
  }

  .calc-title {
    font-size: 1.85rem;
    font-weight: 800;
    margin-bottom: 8px;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .calc-subtitle {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .calc-inputs {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .input-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .input-header label {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-main);
  }

  .num-input {
    width: 110px;
    background: var(--bg-base);
    border: 1px solid var(--border-color);
    color: var(--text-main);
    padding: 6px 12px;
    border-radius: 6px;
    font-weight: 600;
    text-align: right;
    font-family: var(--font-body);
  }

  .num-input:focus {
    outline: none;
    border-color: var(--primary);
  }

  .range-slider {
    width: 100%;
    height: 6px;
    background: var(--border-color);
    border-radius: 3px;
    outline: none;
    -webkit-appearance: none;
    cursor: pointer;
  }

  .range-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--primary);
    box-shadow: 0 0 8px rgba(37, 99, 235, 0.4);
    transition: transform 0.1s ease;
  }

  .range-slider::-webkit-slider-thumb:hover {
    transform: scale(1.15);
  }

  .slider-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: -2px;
  }

  /* TDS Alert Box */
  .tds-alert-box {
    display: flex;
    gap: 12px;
    padding: 16px;
    border-color: rgba(234, 88, 12, 0.25);
    background: rgba(234, 88, 12, 0.04);
    border-radius: 8px;
    align-items: flex-start;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .alert-hidden {
    opacity: 0;
    transform: scale(0.95);
    pointer-events: none;
    display: none !important;
  }

  .alert-icon {
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .alert-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .alert-content strong {
    font-size: 0.9rem;
    color: var(--text-main);
  }

  .alert-content span {
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Outputs Display */
  .calc-outputs {
    position: sticky;
    top: 96px;
  }

  .outputs-container {
    padding: 24px;
    text-align: center;
    background: var(--bg-surface-solid);
    border-color: var(--border-color);
  }

  .outputs-container h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .payout-box {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .highlighted-payout {
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.06) 0%, rgba(0, 242, 254, 0.06) 100%);
    border: 1px dashed rgba(37, 99, 235, 0.3);
    padding: 16px;
    border-radius: 8px;
  }

  .payout-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  .payout-val {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--primary);
    letter-spacing: -0.02em;
  }

  .calc-divider {
    border: none;
    height: 1px;
    background: var(--border-color);
    margin: 20px 0;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    text-align: left;
    margin-bottom: 20px;
  }

  .metric-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .metric-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-top: 4px;
    flex-shrink: 0;
  }

  .principal-dot {
    background: var(--border-hover);
  }

  .interest-dot {
    background: var(--primary);
  }

  .metric-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    display: block;
  }

  .metric-val {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-main);
  }

  .total-financial-value {
    text-align: left;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--bg-base);
    padding: 12px 16px;
    border-radius: 6px;
    border: 1px solid var(--border-color);
  }

  .val-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .total-financial-value strong {
    font-size: 1.1rem;
    color: var(--text-main);
    font-weight: 800;
  }

  /* Donut Chart Visual */
  .chart-container {
    position: relative;
    width: 180px;
    height: 180px;
    margin: 0 auto;
  }

  .chart-bg {
    fill: none;
    stroke: var(--border-color);
  }

  .chart-fill {
    fill: none;
    stroke: var(--primary);
    stroke-linecap: round;
    transition: stroke-dashoffset 0.3s ease;
  }

  .chart-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.1;
  }

  .chart-label span:first-child {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--text-main);
  }

  .chart-label span:last-child {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* Comparison Section */
  .comparison-section {
    border-top: 1px solid var(--border-color);
    padding-top: 32px;
  }

  .comparison-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 4px;
    color: var(--text-main);
  }

  .comparison-subtitle {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .comparison-table-wrapper {
    overflow-x: auto;
    border-radius: 8px;
    border: 1px solid var(--border-color);
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    font-size: 0.9rem;
  }

  .comparison-table th, .comparison-table td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-muted);
  }

  .comparison-table th {
    background: var(--bg-base);
    color: var(--text-main);
    font-weight: 700;
  }

  .comparison-table tbody tr:last-child td {
    border-bottom: none;
  }

  .comparison-table td strong, .comparison-table td span {
    color: var(--text-main);
  }
</style>
