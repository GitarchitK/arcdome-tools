---
---
<div class="compress-tool">
  <!-- Upload Zone -->
  <div class="upload-zone glass-card" id="drop-zone">
    <input type="file" id="file-input" multiple accept="image/png, image/jpeg, image/webp" class="file-hidden" />
    <div class="upload-content">
      <div class="upload-icon-container">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="upload-icon">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
          <polyline points="17 8 12 3 7 8" />
          <line x1="12" y1="3" x2="12" y2="15" />
        </svg>
      </div>
      <h3>Drag & Drop your images here</h3>
      <p>Supports JPG, PNG, and WEBP. Up to 15MB per file.</p>
      <button class="btn btn-secondary" id="browse-btn">Browse Files</button>
    </div>
  </div>

  <!-- Settings and Preview Layout (Hidden until files added) -->
  <div class="tool-workspace" id="tool-workspace" style="display: none;">
    <!-- Settings Panel -->
    <div class="settings-panel glass-card">
      <div class="settings-header">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="settings-icon">
          <circle cx="12" cy="12" r="3" />
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
        </svg>
        <h3>Compression Settings</h3>
      </div>
      
      <div class="settings-content">
        <!-- Compression Mode selector -->
        <div class="control-group">
          <label>Compression Mode</label>
          <div class="mode-toggle">
            <button class="mode-btn active" id="mode-target" type="button">Target Size (KB/MB)</button>
            <button class="mode-btn" id="mode-manual" type="button">Manual Quality</button>
          </div>
        </div>

        <!-- Mode A: Target Size Input -->
        <div class="control-group" id="group-target-size">
          <label for="target-size">Target Size</label>
          <div class="input-unit-group">
            <input type="number" id="target-size" value="100" min="5" max="10000" />
            <select id="target-unit">
              <option value="KB" selected>KB</option>
              <option value="MB">MB</option>
            </select>
          </div>
          <small class="help-text">We'll automatically calculate and adjust quality and scale to match this size.</small>
        </div>

        <!-- Mode B: Manual Quality Slider -->
        <div class="control-group" id="group-quality" style="display: none;">
          <div class="label-with-value">
            <label for="quality-slider">Quality</label>
            <span id="quality-val">80%</span>
          </div>
          <input type="range" id="quality-slider" min="1" max="100" value="80" class="slider" />
          <small class="help-text">Higher quality yields larger files; lower quality reduces file size.</small>
        </div>

        <!-- Target Format Selector -->
        <div class="control-group">
          <label for="target-format">Output Format</label>
          <select id="target-format" class="select-dropdown">
            <option value="original" selected>Original Format</option>
            <option value="jpeg">Convert to JPG</option>
            <option value="png">Convert to PNG</option>
            <option value="webp">Convert to WEBP</option>
          </select>
        </div>

        <button class="btn btn-primary w-full" id="process-btn">Compress Images</button>
      </div>
    </div>

    <!-- Queue & Results Section -->
    <div class="queue-panel">
      <div class="queue-header">
        <h3>Queue (<span id="queue-count">0</span> files)</h3>
        <button class="text-btn" id="clear-all-btn">Clear All</button>
      </div>

      <div class="queue-list" id="queue-list">
        <!-- Rendered items go here -->
      </div>
    </div>
  </div>
</div>

<script>
  // Interface definitions for TypeScript safety
  interface ImageItem {
    id: string;
    file: File;
    status: 'pending' | 'processing' | 'done' | 'failed';
    originalSize: number;
    compressedSize?: number;
    compressedBlob?: Blob;
    outputName?: string;
  }

  // Active state arrays
  let filesQueue: ImageItem[] = [];
  let compressionMode: 'target' | 'manual' = 'target';

  // DOM Elements
  const dropZone = document.getElementById('drop-zone') as HTMLDivElement;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const browseBtn = document.getElementById('browse-btn') as HTMLButtonElement;
  const workspace = document.getElementById('tool-workspace') as HTMLDivElement;
  const queueList = document.getElementById('queue-list') as HTMLDivElement;
  const queueCount = document.getElementById('queue-count') as HTMLSpanElement;
  const clearAllBtn = document.getElementById('clear-all-btn') as HTMLButtonElement;
  
  // Settings Form Elements
  const modeTarget = document.getElementById('mode-target') as HTMLButtonElement;
  const modeManual = document.getElementById('mode-manual') as HTMLButtonElement;
  const groupTarget = document.getElementById('group-target-size') as HTMLDivElement;
  const groupQuality = document.getElementById('group-quality') as HTMLDivElement;
  const targetSizeInput = document.getElementById('target-size') as HTMLInputElement;
  const targetUnitSelect = document.getElementById('target-unit') as HTMLSelectElement;
  const qualitySlider = document.getElementById('quality-slider') as HTMLInputElement;
  const qualityVal = document.getElementById('quality-val') as HTMLSpanElement;
  const targetFormatSelect = document.getElementById('target-format') as HTMLSelectElement;
  const processBtn = document.getElementById('process-btn') as HTMLButtonElement;

  // Toggle modes
  if (modeTarget && modeManual && groupTarget && groupQuality) {
    modeTarget.addEventListener('click', () => {
      compressionMode = 'target';
      modeTarget.classList.add('active');
      modeManual.classList.remove('active');
      groupTarget.style.display = 'block';
      groupQuality.style.display = 'none';
    });

    modeManual.addEventListener('click', () => {
      compressionMode = 'manual';
      modeManual.classList.add('active');
      modeTarget.classList.remove('active');
      groupTarget.style.display = 'none';
      groupQuality.style.display = 'block';
    });
  }

  if (qualitySlider && qualityVal) {
    qualitySlider.addEventListener('input', () => {
      qualityVal.textContent = `${qualitySlider.value}%`;
    });
  }

  // Upload Actions
  if (browseBtn && fileInput) {
    browseBtn.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', handleFileSelect);
  }

  if (dropZone) {
    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('drag-over');
    });

    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('drag-over');
    });

    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('drag-over');
      if (e.dataTransfer?.files) {
        processIncomingFiles(e.dataTransfer.files);
      }
    });
  }

  function handleFileSelect(e: Event) {
    const target = e.target as HTMLInputElement;
    if (target.files) {
      processIncomingFiles(target.files);
    }
  }

  function processIncomingFiles(fileList: FileList) {
    for (let i = 0; i < fileList.length; i++) {
      const file = fileList[i];
      // Limit to 15MB
      if (file.size > 15 * 1024 * 1024) {
        alert(`File "${file.name}" exceeds the 15MB limit.`);
        continue;
      }
      
      const item: ImageItem = {
        id: `img_${Date.now()}_${Math.random().toString(36).substr(2, 5)}`,
        file: file,
        status: 'pending',
        originalSize: file.size
      };
      
      filesQueue.push(item);
    }

    renderQueue();
    updateWorkspaceVisibility();
  }

  function formatBytes(bytes: number, decimals = 2) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ['Bytes', 'KB', 'MB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
  }

  function renderQueue() {
    if (!queueList || !queueCount) return;
    queueCount.textContent = String(filesQueue.length);
    queueList.innerHTML = '';

    filesQueue.forEach(item => {
      const card = document.createElement('div');
      card.className = `queue-card ${item.status}`;
      card.dataset.id = item.id;
      
      let statusIndicator = '';
      let actionBtn = '';

      if (item.status === 'pending') {
        statusIndicator = `<span class="badge badge-pending">Ready</span>`;
      } else if (item.status === 'processing') {
        statusIndicator = `
          <div class="processing-spinner">
            <svg class="spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
            </svg>
            <span>Compressing...</span>
          </div>
        `;
      } else if (item.status === 'done' && item.compressedSize && item.compressedBlob) {
        const savings = Math.round((1 - (item.compressedSize / item.originalSize)) * 100);
        statusIndicator = `
          <div class="result-stats">
            <span class="badge badge-success">-${savings}% Saved</span>
            <span class="comp-size">${formatBytes(item.compressedSize)}</span>
          </div>
        `;
        actionBtn = `
          <button class="btn btn-primary btn-sm btn-download" data-id="${item.id}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
            Download
          </button>
        `;
      } else if (item.status === 'failed') {
        statusIndicator = `<span class="badge badge-failed">Failed</span>`;
      }

      card.innerHTML = `
        <div class="item-preview">
          <img src="" id="thumb_${item.id}" alt="Thumbnail" style="display: none;" />
          <div class="item-fallback-thumb" id="fallback_${item.id}">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
              <circle cx="8.5" cy="8.5" r="1.5" />
              <polyline points="21 15 16 10 5 21" />
            </svg>
          </div>
        </div>
        <div class="item-details">
          <div class="item-header">
            <span class="item-filename" title="${item.file.name}">${item.file.name}</span>
            <button class="item-remove" data-id="${item.id}">&times;</button>
          </div>
          <div class="item-metrics">
            <span class="orig-size">${formatBytes(item.originalSize)}</span>
            <div class="status-action-row">
              ${statusIndicator}
              ${actionBtn}
            </div>
          </div>
        </div>
      `;

      queueList.appendChild(card);
      
      // Load Thumbnail asynchronously
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = document.getElementById(`thumb_${item.id}`) as HTMLImageElement;
        const fallback = document.getElementById(`fallback_${item.id}`) as HTMLDivElement;
        if (img && fallback && e.target?.result) {
          img.src = e.target.result as string;
          img.style.display = 'block';
          fallback.style.display = 'none';
        }
      };
      reader.readAsDataURL(item.file);
    });

    // Wire up remove buttons
    const removeBtns = queueList.querySelectorAll('.item-remove');
    removeBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = (e.currentTarget as HTMLButtonElement).dataset.id;
        filesQueue = filesQueue.filter(f => f.id !== id);
        renderQueue();
        updateWorkspaceVisibility();
      });
    });

    // Wire up download buttons
    const downloadBtns = queueList.querySelectorAll('.btn-download');
    downloadBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = (e.currentTarget as HTMLButtonElement).dataset.id;
        const item = filesQueue.find(f => f.id === id);
        if (item && item.compressedBlob && item.outputName) {
          downloadBlob(item.compressedBlob, item.outputName);
        }
      });
    });
  }

  function downloadBlob(blob: Blob, name: string) {
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = name;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
  }

  function updateWorkspaceVisibility() {
    if (!workspace || !dropZone) return;
    if (filesQueue.length > 0) {
      workspace.style.display = 'grid';
      dropZone.style.padding = '24px';
      dropZone.querySelector('.upload-content h3')!.textContent = 'Add more images';
      dropZone.querySelector('.upload-content p')!.style.display = 'none';
      dropZone.querySelector('.upload-icon-container')!.style.display = 'none';
    } else {
      workspace.style.display = 'none';
      dropZone.style.padding = '48px';
      dropZone.querySelector('.upload-content h3')!.textContent = 'Drag & Drop your images here';
      dropZone.querySelector('.upload-content p')!.style.display = 'block';
      dropZone.querySelector('.upload-icon-container')!.style.display = 'flex';
      fileInput.value = '';
    }
  }

  if (clearAllBtn) {
    clearAllBtn.addEventListener('click', () => {
      filesQueue = [];
      renderQueue();
      updateWorkspaceVisibility();
    });
  }

  // Core Processing Loop
  if (processBtn) {
    processBtn.addEventListener('click', runBatchCompression);
  }

  async function runBatchCompression() {
    processBtn.disabled = true;
    processBtn.textContent = 'Processing...';

    // Settings
    const outputFormat = targetFormatSelect.value;
    const manualQuality = parseInt(qualitySlider.value);
    
    // Parse target size settings
    let targetKB: number | null = null;
    if (compressionMode === 'target') {
      const sizeVal = parseFloat(targetSizeInput.value);
      const unit = targetUnitSelect.value;
      targetKB = unit === 'MB' ? sizeVal * 1024 : sizeVal;
    }

    // Process each item in sequence
    for (let i = 0; i < filesQueue.length; i++) {
      const item = filesQueue[i];
      if (item.status === 'done') continue; // Skip already compressed files
      
      item.status = 'processing';
      renderQueue();

      try {
        const result = await compressSingleImage(item.file, {
          quality: manualQuality,
          targetSizeKB: targetKB,
          format: outputFormat
        });

        item.status = 'done';
        item.compressedSize = result.blob.size;
        item.compressedBlob = result.blob;
        
        // Formulate output filename
        const originalNameParts = item.file.name.split('.');
        originalNameParts.pop(); // Remove extension
        const baseName = originalNameParts.join('.');
        item.outputName = `${baseName}_optimized.${result.ext}`;
      } catch (err) {
        console.error(err);
        item.status = 'failed';
      }

      renderQueue();
    }

    processBtn.disabled = false;
    processBtn.textContent = 'Compress Images';
  }

  // Promise-based file loader
  function loadImageElement(file: File): Promise<HTMLImageElement> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => resolve(img);
        img.onerror = (err) => reject(err);
        img.src = e.target?.result as string;
      };
      reader.onerror = (err) => reject(err);
      reader.readAsDataURL(file);
    });
  }

  interface CompressionResult {
    blob: Blob;
    ext: string;
  }

  async function compressSingleImage(
    file: File, 
    options: { quality: number; targetSizeKB: number | null; format: string }
  ): Promise<CompressionResult> {
    const img = await loadImageElement(file);
    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d');

    if (!ctx) throw new Error('Could not get Canvas Context');

    canvas.width = img.naturalWidth;
    canvas.height = img.naturalHeight;
    ctx.drawImage(img, 0, 0);

    // Mime calculation
    let mimeType = file.type;
    let ext = file.name.split('.').pop() || 'jpg';

    if (options.format === 'jpeg') {
      mimeType = 'image/jpeg';
      ext = 'jpg';
    } else if (options.format === 'png') {
      mimeType = 'image/png';
      ext = 'png';
    } else if (options.format === 'webp') {
      mimeType = 'image/webp';
      ext = 'webp';
    }

    // A. Target Size Logic
    if (options.targetSizeKB !== null) {
      const targetBytes = options.targetSizeKB * 1024;
      
      let activeMime = mimeType;
      let activeExt = ext;

      let minQ = 0.02;
      let maxQ = 0.98;
      let q = 0.75;
      let bestBlob: Blob | null = null;
      let bestDiff = Infinity;

      // 1. Binary search on quality scale first
      for (let step = 0; step < 7; step++) {
        const blob: Blob | null = await new Promise(res => canvas.toBlob(res, activeMime, q));
        if (!blob) break;

        const diff = blob.size - targetBytes;
        
        if (blob.size <= targetBytes) {
          if (Math.abs(diff) < bestDiff) {
            bestBlob = blob;
            bestDiff = Math.abs(diff);
          }
          // Try to increase quality to fill allowed quota
          minQ = q;
        } else {
          // Exceeds quota, decrease quality
          maxQ = q;
        }
        q = (minQ + maxQ) / 2;
      }

      // 2. Fallback: If even quality 0.02 is larger than target, iteratively scale down resolution
      if (!bestBlob || bestBlob.size > targetBytes) {
        let scale = 0.95;
        let scaleSteps = 0;
        
        while (scale > 0.1 && scaleSteps < 7) {
          canvas.width = img.naturalWidth * scale;
          canvas.height = img.naturalHeight * scale;
          
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          ctx.drawImage(img, 0, 0, canvas.width, canvas.height);

          // Test with low quality setting on scaled down Canvas
          const blob: Blob | null = await new Promise(res => canvas.toBlob(res, activeMime, 0.35));
          
          if (blob && blob.size <= targetBytes) {
            bestBlob = blob;
            break;
          }
          scale *= 0.8;
          scaleSteps++;
        }
      }

      // Return best calculated blob
      if (bestBlob) {
        return { blob: bestBlob, ext: activeExt };
      }
      
      // Ultimate absolute compression fallback
      const fallbackBlob: Blob = await new Promise(res => canvas.toBlob(res, activeMime, 0.05)) as Blob;
      return { blob: fallbackBlob, ext: activeExt };
    } 
    
    // B. Manual Quality Slider Logic
    else {
      const q = options.quality / 100;
      const blob: Blob = await new Promise(res => canvas.toBlob(res, mimeType, q)) as Blob;
      return { blob, ext };
    }
  }
</script>

<style>
  .compress-tool {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Drop Zone */
  .upload-zone {
    padding: 48px;
    text-align: center;
    border: 2px dashed var(--border-color);
    cursor: pointer;
    background: rgba(255, 255, 255, 0.55);
    display: flex;
    justify-content: center;
    align-items: center;
    transition: var(--transition-smooth);
    min-height: 200px;
  }

  .upload-zone:hover, .upload-zone.drag-over {
    border-color: var(--primary);
    background: rgba(0, 242, 254, 0.03);
    box-shadow: 0 0 25px rgba(0, 242, 254, 0.05);
  }

  .file-hidden {
    display: none;
  }

  .upload-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .upload-icon-container {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(15, 23, 42, 0.02);
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    transition: var(--transition-smooth);
  }

  .upload-zone:hover .upload-icon-container {
    color: var(--primary);
    background: rgba(0, 242, 254, 0.05);
    border-color: rgba(0, 242, 254, 0.2);
    transform: translateY(-4px);
    box-shadow: 0 4px 15px rgba(0, 242, 254, 0.15);
  }

  .upload-content h3 {
    font-size: 1.35rem;
    font-weight: 600;
  }

  .upload-content p {
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  /* Tool Workspace (Grid layout) */
  .tool-workspace {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 32px;
    align-items: start;
    animation: fadeIn 0.4s ease forwards;
  }

  @media (max-width: 800px) {
    .tool-workspace {
      grid-template-columns: 1fr;
    }
  }

  /* Settings Panel */
  .settings-panel {
    padding: 24px;
    border-color: var(--border-color);
  }

  .settings-header {
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 16px;
    margin-bottom: 24px;
  }

  .settings-icon {
    color: var(--primary);
  }

  .settings-header h3 {
    font-size: 1.15rem;
    font-weight: 600;
  }

  .settings-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .control-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .control-group label {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-main);
  }

  /* Mode toggle button tabs */
  .mode-toggle {
    display: flex;
    background: rgba(15, 23, 42, 0.05);
    border: 1px solid var(--border-color);
    padding: 4px;
    border-radius: 10px;
    gap: 4px;
  }

  .mode-btn {
    flex: 1;
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-family: var(--font-heading);
    font-weight: 500;
    padding: 8px;
    border-radius: 6px;
    cursor: pointer;
    transition: var(--transition-smooth);
  }

  .mode-btn:hover {
    color: var(--text-main);
  }

  .mode-btn.active {
    background: #ffffff;
    border: 1px solid var(--border-color);
    color: var(--primary);
  }

  /* Target Size Input with selector */
  .input-unit-group {
    display: flex;
    background: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    overflow: hidden;
  }

  .input-unit-group input {
    flex: 1;
    border: none;
    background: none;
    color: var(--text-main);
    padding: 12px 16px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    width: 100px;
  }

  .input-unit-group input:focus {
    outline: none;
  }

