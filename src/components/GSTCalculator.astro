---
// GST Calculator Component
---

<div class="calculator-card glass-card">
  <div class="calculator-layout">
    <!-- Inputs Panel -->
    <div class="calc-inputs">
      <h2 class="calc-title">Goods & Services Tax (GST) Calculator</h2>
      <p class="calc-subtitle">Add or remove GST from a base amount with standard slabs and CGST/SGST division.</p>

      <!-- Base Amount -->
      <div class="input-group">
        <div class="input-header">
          <label for="gst-amount">Base Amount (₹)</label>
          <input type="number" id="gst-amount-num" min="100" max="5000000" step="100" value="10000" class="num-input font-semibold" />
        </div>
        <input type="range" id="gst-amount" min="100" max="5000000" step="100" value="10000" class="range-slider" />
        <div class="slider-labels">
          <span>₹100</span>
          <span>₹25L</span>
          <span>₹50L</span>
        </div>
      </div>

      <!-- GST Calculation Type -->
      <div class="toggle-group">
        <label class="toggle-label">Calculation Type</label>
        <div class="toggle-buttons">
          <button class="toggle-btn active" id="type-add" data-type="add">Add GST (Tax Exclusive)</button>
          <button class="toggle-btn" id="type-remove" data-type="remove">Remove GST (Tax Inclusive)</button>
        </div>
      </div>

      <!-- GST Rate Slabs -->
      <div class="input-group">
        <div class="input-header">
          <label for="gst-rate">GST Rate (%)</label>
          <input type="number" id="gst-rate-num" min="0.1" max="50" step="0.1" value="18" class="num-input" />
        </div>
        <input type="range" id="gst-rate" min="0.1" max="50" step="0.1" value="18" class="range-slider" />
        <div class="slider-labels">
          <span>0.1%</span>
          <span>25%</span>
          <span>50%</span>
        </div>
      </div>

      <!-- GST Presets -->
      <div class="presets-group">
        <span class="presets-label">GST Tax Slabs:</span>
        <div class="presets-buttons">
          <button class="gst-preset-btn" data-rate="5">5% (Essentials)</button>
          <button class="gst-preset-btn" data-rate="12">12% (Standard)</button>
          <button class="gst-preset-btn active" data-rate="18">18% (Services/Std)</button>
          <button class="gst-preset-btn" data-rate="28">28% (Luxury)</button>
        </div>
      </div>
    </div>

    <!-- Outputs & Table Panel -->
    <div class="calc-outputs">
      <div class="outputs-container glass-card">
        <h3>GST Breakdown</h3>

        <!-- Big Highlight Payout -->
        <div class="payout-row">
          <div class="payout-box highlighted-payout">
            <span class="payout-label" id="gst-result-label">Total Amount (Inc. GST)</span>
            <span class="payout-val" id="gst-total-val">₹11,800</span>
          </div>
        </div>

        <hr class="calc-divider" />

        <!-- Tax breakdown table -->
        <div class="gst-table-wrapper">
          <table class="gst-breakdown-table">
            <tbody>
              <tr>
                <td><strong>Base Net Price</strong></td>
                <td id="gst-net-val" class="text-right font-medium">₹10,000</td>
              </tr>
              <tr class="text-primary font-medium">
                <td><strong>Total GST Tax</strong></td>
                <td id="gst-tax-val" class="text-right font-bold">₹1,800</td>
              </tr>
              <tr class="sub-tax-row">
                <td>&nbsp;&bull; CGST (Central GST - 50%)</td>
                <td id="gst-cgst-val" class="text-right">₹900</td>
              </tr>
              <tr class="sub-tax-row">
                <td>&nbsp;&bull; SGST (State GST - 50%)</td>
                <td id="gst-sgst-val" class="text-right">₹900</td>
              </tr>
              <tr class="total-row">
                <td><strong>Gross Amount (Invoice Value)</strong></td>
                <td id="gst-gross-val" class="text-right font-bold text-lg">₹11,800</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Elements
  const amountSlider = document.getElementById('gst-amount') as HTMLInputElement;
  const amountNum = document.getElementById('gst-amount-num') as HTMLInputElement;
  const rateSlider = document.getElementById('gst-rate') as HTMLInputElement;
  const rateNum = document.getElementById('gst-rate-num') as HTMLInputElement;
  const typeBtns = document.querySelectorAll('.toggle-buttons .toggle-btn');
  const presetBtns = document.querySelectorAll('.presets-buttons .gst-preset-btn');

  const resultLabel = document.getElementById('gst-result-label');
  const totalValText = document.getElementById('gst-total-val');
  const netValText = document.getElementById('gst-net-val');
  const taxValText = document.getElementById('gst-tax-val');
  const cgstValText = document.getElementById('gst-cgst-val');
  const sgstValText = document.getElementById('gst-sgst-val');
  const grossValText = document.getElementById('gst-gross-val');

  let calculationType = 'add'; // 'add' or 'remove'

  // Synchronizers
  function syncInputs(slider: HTMLInputElement, numInput: HTMLInputElement, callback: () => void) {
    slider.addEventListener('input', () => {
      numInput.value = slider.value;
      callback();
    });
    numInput.addEventListener('change', () => {
      let val = parseFloat(numInput.value);
      const min = parseFloat(numInput.min);
      const max = parseFloat(numInput.max);
      if (isNaN(val)) val = min;
      if (val < min) val = min;
      if (val > max) val = max;
      numInput.value = String(val);
      slider.value = String(val);
      callback();
    });
  }

  // Calculate GST
  function calculateGST() {
    const A = parseFloat(amountSlider.value);
    const R = parseFloat(rateSlider.value);

    let netPrice = 0;
    let taxAmount = 0;
    let grossAmount = 0;

    if (calculationType === 'add') {
      // Add GST (Tax Exclusive)
      netPrice = A;
      taxAmount = A * (R / 100);
      grossAmount = A + taxAmount;
      if (resultLabel) resultLabel.innerText = 'Total Amount (Inc. GST)';
    } else {
      // Remove GST (Tax Inclusive)
      netPrice = A * (100 / (100 + R));
      taxAmount = A - netPrice;
      grossAmount = A;
      if (resultLabel) resultLabel.innerText = 'Original Price (Exc. GST)';
    }

    const cgst = taxAmount / 2;
    const sgst = taxAmount / 2;

    const formatCurrency = (val: number) => {
      return '₹' + Math.round(val).toLocaleString('en-IN');
    };

    // Update UI elements
    if (totalValText) totalValText.innerText = calculationType === 'add' ? formatCurrency(grossAmount) : formatCurrency(netPrice);
    if (netValText) netValText.innerText = formatCurrency(netPrice);
    if (taxValText) taxValText.innerText = formatCurrency(taxAmount);
    if (cgstValText) cgstValText.innerText = formatCurrency(cgst);
    if (sgstValText) sgstValText.innerText = formatCurrency(sgst);
    if (grossValText) grossValText.innerText = formatCurrency(grossAmount);
  }

  // Toggle Type Buttons
  typeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      typeBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      calculationType = btn.getAttribute('data-type') || 'add';
      calculateGST();
    });
  });

  // Preset Rate Buttons
  presetBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      presetBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const rate = btn.getAttribute('data-rate');
      if (rate) {
        rateSlider.value = rate;
        rateNum.value = rate;
        calculateGST();
      }
    });
  });

  // Init
  syncInputs(amountSlider, amountNum, calculateGST);
  syncInputs(rateSlider, rateNum, () => {
    presetBtns.forEach(b => {
      const r = b.getAttribute('data-rate');
      if (r === rateSlider.value) {
        b.classList.add('active');
      } else {
        b.classList.remove('active');
      }
    });
    calculateGST();
  });

  calculateGST();
</script>

<style>
  /* Base Styles matching other calculators */
  .calculator-card {
    padding: 32px;
    background: var(--bg-surface);
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .calculator-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 32px;
    align-items: start;
  }

  @media (max-width: 820px) {
    .calculator-layout {
      grid-template-columns: 1fr;
    }
    .calculator-card {
      padding: 20px;
    }
  }

  .calc-title {
    font-size: 1.85rem;
    font-weight: 800;
    margin-bottom: 8px;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .calc-subtitle {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .calc-inputs {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .input-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .input-header label {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-main);
  }

  .num-input {
    width: 110px;
    background: var(--bg-base);
    border: 1px solid var(--border-color);
    color: var(--text-main);
    padding: 6px 12px;
    border-radius: 6px;
    font-weight: 600;
    text-align: right;
    font-family: var(--font-body);
  }

  .num-input:focus {
    outline: none;
    border-color: var(--primary);
  }

  .range-slider {
    width: 100%;
    height: 6px;
    background: var(--border-color);
    border-radius: 3px;
    outline: none;
    -webkit-appearance: none;
    cursor: pointer;
  }

  .range-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--primary);
    box-shadow: 0 0 8px rgba(37, 99, 235, 0.4);
    transition: transform 0.1s ease;
  }

  .range-slider::-webkit-slider-thumb:hover {
    transform: scale(1.15);
  }

  .slider-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: -2px;
  }

  /* Toggle Buttons styling */
  .toggle-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .toggle-label {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-main);
  }

  .toggle-buttons {
    display: flex;
    background: var(--bg-base);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 4px;
    gap: 4px;
  }

  .toggle-btn {
    flex: 1;
    font-size: 0.85rem;
    padding: 8px 12px;
    border-radius: 6px;
    border: none;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    font-weight: 600;
    transition: var(--transition-smooth);
  }

  .toggle-btn:hover {
    color: var(--text-main);
  }

  .toggle-btn.active {
    background: var(--bg-surface-solid);
    color: var(--primary);
    box-shadow: var(--shadow-premium);
  }

  /* Preset Buttons styling */
  .presets-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: -4px;
  }

  .presets-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .presets-buttons {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .gst-preset-btn {
    font-size: 0.8rem;
    padding: 6px 12px;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    background: var(--bg-btn-sec);
    color: var(--text-main);
    cursor: pointer;
    font-weight: 500;
    transition: var(--transition-smooth);
  }

  .gst-preset-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
    background: var(--primary-glow);
  }

  .gst-preset-btn.active {
    background: var(--primary);
    border-color: var(--primary);
    color: #ffffff;
  }

  /* Outputs Panel */
  .calc-outputs {
    position: sticky;
    top: 96px;
  }

  .outputs-container {
    padding: 24px;
    background: var(--bg-surface-solid);
    border-color: var(--border-color);
  }

  .outputs-container h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    text-align: center;
  }

  .payout-box {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .highlighted-payout {
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.06) 0%, rgba(0, 242, 254, 0.06) 100%);
    border: 1px dashed rgba(37, 99, 235, 0.3);
    padding: 16px;
    border-radius: 8px;
    text-align: center;
  }

  .payout-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  .payout-val {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--primary);
    letter-spacing: -0.02em;
  }

  .calc-divider {
    border: none;
    height: 1px;
    background: var(--border-color);
    margin: 20px 0;
  }

  /* GST Table breakdown */
  .gst-table-wrapper {
    width: 100%;
    margin-top: 10px;
  }

  .gst-breakdown-table {
    width: 100%;
    border-collapse: collapse;
  }

  .gst-breakdown-table td {
    padding: 12px 0;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .gst-breakdown-table tr.sub-tax-row td {
    padding: 8px 0;
    font-size: 0.85rem;
    color: var(--text-muted);
    border-bottom: 1px dashed var(--border-color);
  }

  .gst-breakdown-table tr.total-row td {
    padding-top: 16px;
    border-bottom: none;
    color: var(--text-main);
  }

  .text-right {
    text-align: right;
  }

  .font-medium {
    font-weight: 500;
  }

  .font-bold {
    font-weight: 700;
  }

  .text-lg {
    font-size: 1.2rem;
  }
</style>
