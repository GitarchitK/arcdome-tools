---
---
<div class="converter-tool">
  <!-- Upload Zone -->
  <div class="upload-zone glass-card" id="conv-drop-zone">
    <input type="file" id="conv-file-input" multiple accept="image/png, image/jpeg, image/webp" class="file-hidden" />
    <div class="upload-content">
      <div class="upload-icon-container">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="upload-icon">
          <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" />
          <path d="m15 5 4 4" />
        </svg>
      </div>
      <h3>Drag & Drop images to convert</h3>
      <p>Supports PNG, JPG, WEBP. Fast in-browser transformation.</p>
      <button class="btn btn-secondary" id="conv-browse-btn">Browse Files</button>
    </div>
  </div>

  <!-- Settings and Preview Layout (Hidden until files added) -->
  <div class="tool-workspace" id="conv-workspace" style="display: none;">
    <!-- Settings Panel -->
    <div class="settings-panel glass-card">
      <div class="settings-header">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="settings-icon">
          <path d="M4 12h16M14 6l6 6-6 6" />
        </svg>
        <h3>Converter Settings</h3>
      </div>
      
      <div class="settings-content">
        <!-- Target Format Selector -->
        <div class="control-group">
          <label for="conv-target-format">Convert All To</label>
          <select id="conv-target-format" class="select-dropdown">
            <option value="webp" selected>WEBP (Highly Recommended)</option>
            <option value="jpeg">JPG / JPEG</option>
            <option value="png">PNG (Lossless)</option>
            <option value="avif">AVIF (Ultra Compression)</option>
          </select>
          <small class="help-text" id="avif-support-note"></small>
        </div>

        <button class="btn btn-primary w-full" id="conv-process-btn">Convert Images</button>
      </div>
    </div>

    <!-- Queue & Results Section -->
    <div class="queue-panel">
      <div class="queue-header">
        <h3>Queue (<span id="conv-queue-count">0</span> files)</h3>
        <button class="text-btn" id="conv-clear-all-btn">Clear All</button>
      </div>

      <div class="queue-list" id="conv-queue-list">
        <!-- Rendered items go here -->
      </div>
    </div>
  </div>
</div>

<script>
  interface ConvertItem {
    id: string;
    file: File;
    status: 'pending' | 'converting' | 'done' | 'failed';
    originalSize: number;
    originalExt: string;
    convertedSize?: number;
    convertedBlob?: Blob;
    outputName?: string;
  }

  let convertQueue: ConvertItem[] = [];

  // DOM Elements
  const dropZone = document.getElementById('conv-drop-zone') as HTMLDivElement;
  const fileInput = document.getElementById('conv-file-input') as HTMLInputElement;
  const browseBtn = document.getElementById('conv-browse-btn') as HTMLButtonElement;
  const workspace = document.getElementById('conv-workspace') as HTMLDivElement;
  const queueList = document.getElementById('conv-queue-list') as HTMLDivElement;
  const queueCount = document.getElementById('conv-queue-count') as HTMLSpanElement;
  const clearAllBtn = document.getElementById('conv-clear-all-btn') as HTMLButtonElement;
  const processBtn = document.getElementById('conv-process-btn') as HTMLButtonElement;
  const targetFormatSelect = document.getElementById('conv-target-format') as HTMLSelectElement;
  const avifNote = document.getElementById('avif-support-note') as HTMLSmallElement;

  // Check AVIF encoding support on load
  detectAvifSupport();

  async function detectAvifSupport() {
    if (!avifNote) return;
    const canvas = document.createElement('canvas');
    canvas.width = 1;
    canvas.height = 1;
    
    const supportsAvif = await new Promise(resolve => {
      try {
        canvas.toBlob((blob) => {
          resolve(blob && blob.type === 'image/avif');
        }, 'image/avif');
      } catch (e) {
        resolve(false);
      }
    });

    if (!supportsAvif) {
      // Find avif option and style/disclaim it
      const avifOption = targetFormatSelect.querySelector('option[value="avif"]') as HTMLOptionElement;
      if (avifOption) {
        avifOption.text = 'AVIF (Not supported by your browser)';
        avifOption.disabled = true;
      }
      avifNote.textContent = 'Note: AVIF writing is not natively supported by your current browser. Try WebP for similar results.';
      avifNote.style.color = 'var(--text-muted)';
    } else {
      avifNote.textContent = 'AVIF compression is fully supported by your browser.';
      avifNote.style.color = 'var(--accent-green)';
    }
  }

  // Upload Actions
  if (browseBtn && fileInput) {
    browseBtn.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', handleFileSelect);
  }

  if (dropZone) {
    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('drag-over');
    });

    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('drag-over');
    });

    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('drag-over');
      if (e.dataTransfer?.files) {
        processIncomingFiles(e.dataTransfer.files);
      }
    });
  }

  function handleFileSelect(e: Event) {
    const target = e.target as HTMLInputElement;
    if (target.files) {
      processIncomingFiles(target.files);
    }
  }

  function processIncomingFiles(fileList: FileList) {
    for (let i = 0; i < fileList.length; i++) {
      const file = fileList[i];
      if (file.size > 15 * 1024 * 1024) {
        alert(`File "${file.name}" exceeds the 15MB size limit.`);
        continue;
      }
      
      const ext = file.name.split('.').pop()?.toUpperCase() || 'IMG';
      
      const item: ConvertItem = {
        id: `conv_${Date.now()}_${Math.random().toString(36).substr(2, 5)}`,
        file: file,
        status: 'pending',
        originalSize: file.size,
        originalExt: ext
      };
      
      convertQueue.push(item);
    }

    renderQueue();
    updateWorkspaceVisibility();
  }

  function formatBytes(bytes: number, decimals = 2) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ['Bytes', 'KB', 'MB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
  }

  function renderQueue() {
    if (!queueList || !queueCount) return;
    queueCount.textContent = String(convertQueue.length);
    queueList.innerHTML = '';

    convertQueue.forEach(item => {
      const card = document.createElement('div');
      card.className = `queue-card ${item.status}`;
      card.dataset.id = item.id;
      
      let statusIndicator = '';
      let actionBtn = '';

      if (item.status === 'pending') {
        statusIndicator = `<span class="badge badge-pending">Ready</span>`;
      } else if (item.status === 'converting') {
        statusIndicator = `
          <div class="processing-spinner">
            <svg class="spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
            </svg>
            <span>Converting...</span>
          </div>
        `;
      } else if (item.status === 'done' && item.convertedSize && item.convertedBlob) {
        const ext = item.outputName?.split('.').pop()?.toUpperCase() || 'NEW';
        statusIndicator = `
          <div class="result-stats">
            <span class="badge badge-success">Converted to ${ext}</span>
            <span class="comp-size">${formatBytes(item.convertedSize)}</span>
          </div>
        `;
        actionBtn = `
          <button class="btn btn-primary btn-sm btn-download" data-id="${item.id}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
            Download
          </button>
        `;
      } else if (item.status === 'failed') {
        statusIndicator = `<span class="badge badge-failed">Failed</span>`;
      }

      card.innerHTML = `
        <div class="item-preview">
          <img src="" id="conv_thumb_${item.id}" alt="Thumbnail" style="display: none;" />
          <div class="item-fallback-thumb" id="conv_fallback_${item.id}">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
              <circle cx="8.5" cy="8.5" r="1.5" />
              <polyline points="21 15 16 10 5 21" />
            </svg>
          </div>
        </div>
        <div class="item-details">
          <div class="item-header">
            <span class="item-filename" title="${item.file.name}">${item.file.name}</span>
            <button class="item-remove" data-id="${item.id}">&times;</button>
          </div>
          <div class="item-metrics">
            <span class="orig-size">${formatBytes(item.originalSize)} (${item.originalExt})</span>
            <div class="status-action-row">
              ${statusIndicator}
              ${actionBtn}
            </div>
          </div>
        </div>
      `;

      queueList.appendChild(card);
      
      // Load Thumbnail asynchronously
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = document.getElementById(`conv_thumb_${item.id}`) as HTMLImageElement;
        const fallback = document.getElementById(`conv_fallback_${item.id}`) as HTMLDivElement;
        if (img && fallback && e.target?.result) {
          img.src = e.target.result as string;
          img.style.display = 'block';
          fallback.style.display = 'none';
        }
      };
      reader.readAsDataURL(item.file);
    });

    // Wire remove buttons
    const removeBtns = queueList.querySelectorAll('.item-remove');
    removeBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = (e.currentTarget as HTMLButtonElement).dataset.id;
        convertQueue = convertQueue.filter(f => f.id !== id);
        renderQueue();
        updateWorkspaceVisibility();
      });
    });

    // Wire download buttons
    const downloadBtns = queueList.querySelectorAll('.btn-download');
    downloadBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = (e.currentTarget as HTMLButtonElement).dataset.id;
        const item = convertQueue.find(f => f.id === id);
        if (item && item.convertedBlob && item.outputName) {
          downloadBlob(item.convertedBlob, item.outputName);
        }
      });
    });
  }

  function downloadBlob(blob: Blob, name: string) {
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = name;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
  }

  function updateWorkspaceVisibility() {
    if (!workspace || !dropZone) return;
    if (convertQueue.length > 0) {
      workspace.style.display = 'grid';
      dropZone.style.padding = '24px';
      dropZone.querySelector('.upload-content h3')!.textContent = 'Add more images';
      dropZone.querySelector('.upload-content p')!.style.display = 'none';
      dropZone.querySelector('.upload-icon-container')!.style.display = 'none';
    } else {
      workspace.style.display = 'none';
      dropZone.style.padding = '48px';
      dropZone.querySelector('.upload-content h3')!.textContent = 'Drag & Drop images to convert';
      dropZone.querySelector('.upload-content p')!.style.display = 'block';
      dropZone.querySelector('.upload-icon-container')!.style.display = 'flex';
      fileInput.value = '';
    }
  }

  if (clearAllBtn) {
    clearAllBtn.addEventListener('click', () => {
      convertQueue = [];
      renderQueue();
      updateWorkspaceVisibility();
    });
  }

  // Core Conversion Loop
  if (processBtn) {
    processBtn.addEventListener('click', runBatchConversion);
  }

  async function runBatchConversion() {
    processBtn.disabled = true;
    processBtn.textContent = 'Converting...';

    const targetFormat = targetFormatSelect.value;

    for (let i = 0; i < convertQueue.length; i++) {
      const item = convertQueue[i];
      if (item.status === 'done') continue;
      
      item.status = 'converting';
      renderQueue();

      try {
        const result = await convertSingleImage(item.file, targetFormat);

        item.status = 'done';
        item.convertedSize = result.blob.size;
        item.convertedBlob = result.blob;
        
        const originalNameParts = item.file.name.split('.');
        originalNameParts.pop();
        const baseName = originalNameParts.join('.');
        item.outputName = `${baseName}_converted.${result.ext}`;
      } catch (err) {
        console.error(err);
        item.status = 'failed';
      }

      renderQueue();
    }

    processBtn.disabled = false;
    processBtn.textContent = 'Convert Images';
  }

  function loadImageElement(file: File): Promise<HTMLImageElement> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => resolve(img);
        img.onerror = (err) => reject(err);
        img.src = e.target?.result as string;
      };
      reader.onerror = (err) => reject(err);
      reader.readAsDataURL(file);
    });
  }

  interface ConversionResult {
    blob: Blob;
    ext: string;
  }

  async function convertSingleImage(file: File, format: string): Promise<ConversionResult> {
    const img = await loadImageElement(file);
    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d');

    if (!ctx) throw new Error('Could not get Canvas context');

    canvas.width = img.naturalWidth;
    canvas.height = img.naturalHeight;
    ctx.drawImage(img, 0, 0);

    let mimeType = 'image/webp';
    let ext = 'webp';

    if (format === 'jpeg') {
      mimeType = 'image/jpeg';
      ext = 'jpg';
    } else if (format === 'png') {
      mimeType = 'image/png';
      ext = 'png';
    } else if (format === 'avif') {
      mimeType = 'image/avif';
      ext = 'avif';
    }

    const blob: Blob = await new Promise((resolve, reject) => {
      try {
        // High quality setting for layout conversion
        canvas.toBlob((b) => {
          if (b) resolve(b);
          else reject(new Error('Conversion returned null blob'));
        }, mimeType, 0.92);
      } catch (e) {
        reject(e);
      }
    }) as Blob;

    return { blob, ext };
  }
</script>

<style>
  /* Reuse design rules from ImageCompressor */
  .converter-tool {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Drop Zone */
  .upload-zone {
    padding: 48px;
    text-align: center;
    border: 2px dashed var(--border-color);
    cursor: pointer;
    background: rgba(255, 255, 255, 0.55);
    display: flex;
    justify-content: center;
    align-items: center;
    transition: var(--transition-smooth);
    min-height: 200px;
  }

  .upload-zone:hover, .upload-zone.drag-over {
    border-color: var(--primary);
    background: rgba(0, 242, 254, 0.03);
    box-shadow: 0 0 25px rgba(0, 242, 254, 0.05);
  }

  .file-hidden {
    display: none;
  }

  .upload-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .upload-icon-container {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(15, 23, 42, 0.02);
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    transition: var(--transition-smooth);
  }

  .upload-zone:hover .upload-icon-container {
    color: var(--primary);
    background: rgba(0, 242, 254, 0.05);
    border-color: rgba(0, 242, 254, 0.2);
    transform: translateY(-4px);
    box-shadow: 0 4px 15px rgba(0, 242, 254, 0.15);
  }

  .upload-content h3 {
    font-size: 1.35rem;
    font-weight: 600;
  }

  .upload-content p {
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  /* Tool Workspace (Grid layout) */
  .tool-workspace {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 32px;
    align-items: start;
    animation: fadeIn 0.4s ease forwards;
  }

  @media (max-width: 800px) {
    .tool-workspace {
      grid-template-columns: 1fr;
    }
  }

  /* Settings Panel */
  .settings-panel {
    padding: 24px;
    border-color: var(--border-color);
  }

  .settings-header {
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 16px;
    margin-bottom: 24px;
  }

  .settings-icon {
    color: var(--primary);
  }

  .settings-header h3 {
    font-size: 1.15rem;
    font-weight: 600;
  }

  .settings-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .control-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .control-group label {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-main);
  }

  /* Dropdown Selector */
  .select-dropdown {
    background: #ffffff;
    border: 1px solid var(--border-color);
    color: var(--text-main);
    padding: 12px 16px;
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    cursor: pointer;
    width: 100%;
  }

  .select-dropdown:focus {
    outline: none;
    border-color: var(--primary);
  }

  .help-text {
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .w-full {
    width: 100%;
  }

  /* Queue Panel */
  .queue-panel {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .queue-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .queue-header h3 {
    font-size: 1.25rem;
    font-weight: 600;
  }

  .text-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 0.9rem;
    cursor: pointer;
    transition: var(--transition-smooth);
  }

  .text-btn:hover {
    color: var(--accent-red);
  }

  .queue-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-height: 520px;
    overflow-y: auto;
    padding-right: 4px;
  }

  /* Queue Item Card */
  #conv-queue-list :global(.queue-card) {
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    gap: 16px;
    align-items: center;
    transition: var(--transition-smooth);
  }

  #conv-queue-list :global(.queue-card:hover) {
    border-color: rgba(255, 255, 255, 0.15);
  }

  #conv-queue-list :global(.item-preview) {
    width: 56px;
    height: 56px;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  #conv-queue-list :global(.item-preview img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #conv-queue-list :global(.item-fallback-thumb) {
    color: var(--text-muted);
    opacity: 0.4;
  }

  #conv-queue-list :global(.item-details) {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  #conv-queue-list :global(.item-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  #conv-queue-list :global(.item-filename) {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-main);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  #conv-queue-list :global(.item-remove) {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 1.35rem;
    cursor: pointer;
    line-height: 1;
    padding: 0 4px;
    transition: var(--transition-smooth);
  }

  #conv-queue-list :global(.item-remove:hover) {
    color: var(--accent-red);
  }

  #conv-queue-list :global(.item-metrics) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
  }

  #conv-queue-list :global(.orig-size) {
    color: var(--text-muted);
  }

  #conv-queue-list :global(.status-action-row) {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* Badges */
  #conv-queue-list :global(.badge) {
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    display: inline-block;
  }

  #conv-queue-list :global(.badge-pending) {
    background: rgba(15, 23, 42, 0.05);
    border: 1px solid var(--border-color);
    color: var(--text-muted);
  }

  #conv-queue-list :global(.badge-success) {
    background: rgba(56, 176, 0, 0.1);
    border: 1px solid rgba(56, 176, 0, 0.2);
    color: #39db02;
  }

  #conv-queue-list :global(.badge-failed) {
    background: rgba(255, 77, 109, 0.1);
    border: 1px solid rgba(255, 77, 109, 0.2);
    color: var(--accent-red);
  }

  #conv-queue-list :global(.comp-size) {
    color: var(--text-main);
    font-weight: 600;
  }

  #conv-queue-list :global(.processing-spinner) {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--primary);
  }

  #conv-queue-list :global(.processing-spinner svg) {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    100% { transform: rotate(360deg); }
  }

  #conv-queue-list :global(.btn-download) {
    padding: 6px 12px;
    font-size: 0.8rem;
    border-radius: 6px;
    gap: 4px;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
