---
// FD Calculator component
---

<div class="calculator-card glass-card">
  <div class="calculator-layout">
    <!-- Inputs Panel -->
    <div class="calc-inputs">
      <h2 class="calc-title">Fixed Deposit (FD) Calculator</h2>
      <p class="calc-subtitle">Calculate your maturity value and interest earnings with quarterly compounding.</p>

      <!-- Principal Amount -->
      <div class="input-group">
        <div class="input-header">
          <label for="fd-principal">Total Investment (₹)</label>
          <input type="number" id="fd-principal-num" min="1000" max="10000000" value="100000" class="num-input" />
        </div>
        <input type="range" id="fd-principal" min="1000" max="10000000" step="5000" value="100000" class="range-slider" />
        <div class="slider-labels">
          <span>₹1K</span>
          <span>₹50L</span>
          <span>₹1Cr</span>
        </div>
      </div>

      <!-- Interest Rate -->
      <div class="input-group">
        <div class="input-header">
          <label for="fd-rate">Rate of Interest (% p.a.)</label>
          <input type="number" id="fd-rate-num" min="1" max="15" step="0.05" value="7.10" class="num-input" />
        </div>
        <input type="range" id="fd-rate" min="1" max="15" step="0.05" value="7.10" class="range-slider" />
        <div class="slider-labels">
          <span>1%</span>
          <span>8%</span>
          <span>15%</span>
        </div>
      </div>

      <!-- Tenure -->
      <div class="input-group">
        <div class="input-header">
          <label for="fd-tenure">Tenure</label>
          <div class="tenure-input-wrapper">
            <input type="number" id="fd-tenure-num" min="1" max="120" value="5" class="num-input tenure-num" />
            <select id="fd-tenure-unit" class="select-dropdown tenure-unit">
              <option value="years" selected>Years</option>
              <option value="months">Months</option>
              <option value="days">Days</option>
            </select>
          </div>
        </div>
        <input type="range" id="fd-tenure" min="1" max="25" step="1" value="5" class="range-slider" />
        <div class="slider-labels" id="fd-tenure-slider-labels">
          <span>1 Yr</span>
          <span>13 Yrs</span>
          <span>25 Yrs</span>
        </div>
      </div>

      <!-- Senior Citizen Toggle -->
      <div class="toggle-group glass-card">
        <div class="toggle-text">
          <strong>Senior Citizen Rates</strong>
          <span>Apply additional interest premium (+0.50% p.a.)</span>
        </div>
        <label class="switch">
          <input type="checkbox" id="fd-senior-toggle" />
          <span class="slider round"></span>
        </label>
      </div>

      <!-- Compounding Interval -->
      <div class="input-group">
        <label for="fd-compound">Compounding Frequency</label>
        <select id="fd-compound" class="select-dropdown w-full">
          <option value="4" selected>Quarterly (Standard Bank FD)</option>
          <option value="12">Monthly</option>
          <option value="2">Half-Yearly</option>
          <option value="1">Yearly</option>
          <option value="0">Simple Interest (No Compounding)</option>
        </select>
      </div>
    </div>

    <!-- Outputs & Charts Panel -->
    <div class="calc-outputs">
      <div class="outputs-container glass-card">
        <h3>Maturity Details</h3>

        <!-- Big Number Result -->
        <div class="maturity-amount-display">
          <span class="amount-label">Maturity Amount</span>
          <span class="amount-val" id="fd-maturity-val">₹1,41,762</span>
        </div>

        <hr class="calc-divider" />

        <!-- Metrics Grid -->
        <div class="metrics-grid">
          <div class="metric-item">
            <span class="metric-dot principal-dot"></span>
            <div>
              <span class="metric-label">Invested Principal</span>
              <span class="metric-val" id="fd-invested-val">₹1,00,000</span>
            </div>
          </div>
          <div class="metric-item">
            <span class="metric-dot interest-dot"></span>
            <div>
              <span class="metric-label">Est. Interest Earned</span>
              <span class="metric-val text-primary" id="fd-interest-val">₹41,762</span>
            </div>
          </div>
        </div>

        <!-- SVG Donut Chart Visual -->
        <div class="chart-container">
          <svg width="180" height="180" viewBox="0 0 180 180" class="donut-chart">
            <circle cx="90" cy="90" r="70" class="chart-bg" stroke-width="16" />
            <circle cx="90" cy="90" r="70" class="chart-fill" id="fd-chart-fill" stroke-width="16" stroke-dasharray="439.8" stroke-dashoffset="130" transform="rotate(-90 90 90)" />
          </svg>
          <div class="chart-label">
            <span id="fd-ratio-pct">29.5%</span>
            <span>Interest</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bank Rates Presets Section -->
  <div class="bank-rates-section">
    <h3 class="bank-rates-title">Compare Top Indian Bank FD Rates (2026)</h3>
    <p class="bank-rates-subtitle">Select any rate preset below to instantly load it into the calculator.</p>
    <div class="rates-grid">
      <!-- SBI -->
      <div class="bank-rate-card glass-card" data-bank="sbi" data-reg="6.80" data-snr="7.30">
        <div class="bank-header">
          <span class="bank-logo-placeholder sbi-logo">SBI</span>
          <strong>State Bank of India</strong>
        </div>
        <div class="rate-values">
          <div class="rate-col">
            <span>Regular</span>
            <strong class="reg-rate-display">6.80%</strong>
          </div>
          <div class="rate-col">
            <span>Senior</span>
            <strong class="snr-rate-display">7.30%</strong>
          </div>
        </div>
        <button class="btn btn-secondary btn-sm use-rate-btn">Apply Rate</button>
      </div>

      <!-- HDFC -->
      <div class="bank-rate-card glass-card" data-bank="hdfc" data-reg="7.25" data-snr="7.75">
        <div class="bank-header">
          <span class="bank-logo-placeholder hdfc-logo">HDFC</span>
          <strong>HDFC Bank</strong>
        </div>
        <div class="rate-values">
          <div class="rate-col">
            <span>Regular</span>
            <strong class="reg-rate-display">7.25%</strong>
          </div>
          <div class="rate-col">
            <span>Senior</span>
            <strong class="snr-rate-display">7.75%</strong>
          </div>
        </div>
        <button class="btn btn-secondary btn-sm use-rate-btn">Apply Rate</button>
      </div>

      <!-- ICICI -->
      <div class="bank-rate-card glass-card" data-bank="icici" data-reg="7.20" data-snr="7.70">
        <div class="bank-header">
          <span class="bank-logo-placeholder icici-logo">ICICI</span>
          <strong>ICICI Bank</strong>
        </div>
        <div class="rate-values">
          <div class="rate-col">
            <span>Regular</span>
            <strong class="reg-rate-display">7.20%</strong>
          </div>
          <div class="rate-col">
            <span>Senior</span>
            <strong class="snr-rate-display">7.70%</strong>
          </div>
        </div>
        <button class="btn btn-secondary btn-sm use-rate-btn">Apply Rate</button>
      </div>

      <!-- Axis -->
      <div class="bank-rate-card glass-card" data-bank="axis" data-reg="7.20" data-snr="7.75">
        <div class="bank-header">
          <span class="bank-logo-placeholder axis-logo">AXIS</span>
          <strong>Axis Bank</strong>
        </div>
        <div class="rate-values">
          <div class="rate-col">
            <span>Regular</span>
            <strong class="reg-rate-display">7.20%</strong>
          </div>
          <div class="rate-col">
            <span>Senior</span>
            <strong class="snr-rate-display">7.75%</strong>
          </div>
        </div>
        <button class="btn btn-secondary btn-sm use-rate-btn">Apply Rate</button>
      </div>

      <!-- PNB -->
      <div class="bank-rate-card glass-card" data-bank="pnb" data-reg="7.25" data-snr="7.75">
        <div class="bank-header">
          <span class="bank-logo-placeholder pnb-logo">PNB</span>
          <strong>Punjab National Bank</strong>
        </div>
        <div class="rate-values">
          <div class="rate-col">
            <span>Regular</span>
            <strong class="reg-rate-display">7.25%</strong>
          </div>
          <div class="rate-col">
            <span>Senior</span>
            <strong class="snr-rate-display">7.75%</strong>
          </div>
        </div>
        <button class="btn btn-secondary btn-sm use-rate-btn">Apply Rate</button>
      </div>
    </div>
  </div>
</div>

<script>
  // Elements
  const principalSlider = document.getElementById('fd-principal') as HTMLInputElement;
  const principalNum = document.getElementById('fd-principal-num') as HTMLInputElement;
  const rateSlider = document.getElementById('fd-rate') as HTMLInputElement;
  const rateNum = document.getElementById('fd-rate-num') as HTMLInputElement;
  const tenureSlider = document.getElementById('fd-tenure') as HTMLInputElement;
  const tenureNum = document.getElementById('fd-tenure-num') as HTMLInputElement;
  const tenureUnitSelect = document.getElementById('fd-tenure-unit') as HTMLSelectElement;
  const seniorToggle = document.getElementById('fd-senior-toggle') as HTMLInputElement;
  const compoundSelect = document.getElementById('fd-compound') as HTMLSelectElement;

  const maturityAmountText = document.getElementById('fd-maturity-val');
  const investedAmountText = document.getElementById('fd-invested-val');
  const interestAmountText = document.getElementById('fd-interest-val');
  const ratioText = document.getElementById('fd-ratio-pct');
  const chartFillCircle = document.getElementById('fd-chart-fill');

  const tenureSliderLabels = document.getElementById('fd-tenure-slider-labels');

  // Synchronizers
  function syncInputs(slider: HTMLInputElement, numInput: HTMLInputElement, callback: () => void) {
    slider.addEventListener('input', () => {
      numInput.value = slider.value;
      callback();
    });
    numInput.addEventListener('change', () => {
      let val = parseFloat(numInput.value);
      const min = parseFloat(numInput.min);
      const max = parseFloat(numInput.max);
      if (isNaN(val)) val = min;
      if (val < min) val = min;
      if (val > max) val = max;
      numInput.value = String(val);
      slider.value = String(val);
      callback();
    });
  }

  // Handle unit change for Tenure Slider limits
  tenureUnitSelect.addEventListener('change', () => {
    const unit = tenureUnitSelect.value;
    if (unit === 'years') {
      tenureSlider.min = '1';
      tenureSlider.max = '25';
      tenureSlider.step = '1';
      tenureNum.min = '1';
      tenureNum.max = '25';
      tenureNum.value = '5';
      tenureSlider.value = '5';
      if (tenureSliderLabels) {
        tenureSliderLabels.innerHTML = '<span>1 Yr</span><span>13 Yrs</span><span>25 Yrs</span>';
      }
    } else if (unit === 'months') {
      tenureSlider.min = '1';
      tenureSlider.max = '120';
      tenureSlider.step = '1';
      tenureNum.min = '1';
      tenureNum.max = '120';
      tenureNum.value = '60';
      tenureSlider.value = '60';
      if (tenureSliderLabels) {
        tenureSliderLabels.innerHTML = '<span>1 M</span><span>60 M</span><span>120 M</span>';
      }
    } else { // days
      tenureSlider.min = '7';
      tenureSlider.max = '365';
      tenureSlider.step = '1';
      tenureNum.min = '7';
      tenureNum.max = '365';
      tenureNum.value = '180';
      tenureSlider.value = '180';
      if (tenureSliderLabels) {
        tenureSliderLabels.innerHTML = '<span>7 D</span><span>186 D</span><span>365 D</span>';
      }
    }
    calculateFD();
  });

  // Calculate FD
  function calculateFD() {
    const P = parseFloat(principalSlider.value);
    let r = parseFloat(rateSlider.value) / 100;
    const tVal = parseFloat(tenureSlider.value);
    const unit = tenureUnitSelect.value;
    const isSenior = seniorToggle.checked;
    const n = parseInt(compoundSelect.value);

    // Format currency Indian Style (e.g. ₹1,41,762)
    const formatCurrency = (val: number) => {
      return '₹' + Math.round(val).toLocaleString('en-IN');
    };

    // Calculate time in fractional years
    let t = tVal;
    if (unit === 'months') {
      t = tVal / 12;
    } else if (unit === 'days') {
      t = tVal / 365;
    }

    // Fixed Deposit Calculation
    let A = 0;
    if (n === 0) {
      // Simple Interest: A = P(1 + rt)
      A = P * (1 + r * t);
    } else {
      // Short term FD less than 6 months (approx 180 days) standard simple interest exception
      const isShortTerm = (unit === 'days' && tVal < 180) || (unit === 'months' && tVal < 6) || (unit === 'years' && tVal < 0.5);
      if (isShortTerm) {
        A = P * (1 + r * t);
      } else {
        // Compound Interest: A = P(1 + r/n)^(nt)
        A = P * Math.pow(1 + r / n, n * t);
      }
    }

    const interest = A - P;

    // Update Output Numbers
    if (maturityAmountText) maturityAmountText.innerText = formatCurrency(A);
    if (investedAmountText) investedAmountText.innerText = formatCurrency(P);
    if (interestAmountText) interestAmountText.innerText = formatCurrency(interest);

    // Update Donut Chart
    const total = A;
    const interestPct = total > 0 ? (interest / total) * 100 : 0;
    if (ratioText) ratioText.innerText = interestPct.toFixed(1) + '%';

    if (chartFillCircle) {
      const maxOffset = 439.8; // 2 * PI * r (2 * 3.14159 * 70)
      const offset = maxOffset - (interestPct / 100) * maxOffset;
      chartFillCircle.setAttribute('stroke-dashoffset', String(offset));
    }
  }

  // Handle Senior Citizen toggle addition
  let previousRate = parseFloat(rateSlider.value);
  seniorToggle.addEventListener('change', () => {
    let currentRate = parseFloat(rateSlider.value);
    if (seniorToggle.checked) {
      // Add 0.50%
      currentRate = Math.min(15, currentRate + 0.50);
    } else {
      // Subtract 0.50%
      currentRate = Math.max(1, currentRate - 0.50);
    }
    rateSlider.value = String(currentRate);
    rateNum.value = String(currentRate);
    calculateFD();
  });

  // Bank Presets click handlers
  const rateCards = document.querySelectorAll('.bank-rate-card');
  rateCards.forEach(card => {
    const applyBtn = card.querySelector('.use-rate-btn');
    applyBtn?.addEventListener('click', () => {
      const isSenior = seniorToggle.checked;
      const rateValStr = isSenior ? card.getAttribute('data-snr') : card.getAttribute('data-reg');
      if (rateValStr) {
        const rateVal = parseFloat(rateValStr);
        rateSlider.value = String(rateVal);
        rateNum.value = String(rateVal);
        calculateFD();

        // Visual flash indication
        card.classList.add('applied-flash');
        setTimeout(() => card.classList.remove('applied-flash'), 500);
      }
    });
  });

  // Init
  syncInputs(principalSlider, principalNum, calculateFD);
  syncInputs(rateSlider, rateNum, calculateFD);
  syncInputs(tenureSlider, tenureNum, calculateFD);
  calculateFD();
</script>

<style>
  .calculator-card {
    padding: 32px;
    background: var(--bg-surface);
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .calculator-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 32px;
    align-items: start;
  }

  @media (max-width: 820px) {
    .calculator-layout {
      grid-template-columns: 1fr;
    }
    .calculator-card {
      padding: 20px;
    }
  }

  .calc-title {
    font-size: 1.85rem;
    font-weight: 800;
    margin-bottom: 8px;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .calc-subtitle {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .calc-inputs {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .input-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .input-header label {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-main);
  }

  .num-input {
    width: 100px;
    background: var(--bg-base);
    border: 1px solid var(--border-color);
    color: var(--text-main);
    padding: 6px 12px;
    border-radius: 6px;
    font-weight: 600;
    text-align: right;
    font-family: var(--font-body);
  }

  .num-input:focus {
    outline: none;
    border-color: var(--primary);
  }

  .range-slider {
    width: 100%;
    height: 6px;
    background: var(--border-color);
    border-radius: 3px;
    outline: none;
    -webkit-appearance: none;
    cursor: pointer;
  }

  .range-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--primary);
    box-shadow: 0 0 8px rgba(37, 99, 235, 0.4);
    transition: transform 0.1s ease;
  }

  .range-slider::-webkit-slider-thumb:hover {
    transform: scale(1.15);
  }

  .slider-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: -2px;
  }

  .tenure-input-wrapper {
    display: flex;
    gap: 8px;
  }

  .tenure-num {
    width: 70px;
  }

  .tenure-unit {
    width: 90px;
    padding: 6px;
    font-size: 0.85rem;
  }

  /* Toggle Button Styles */
  .toggle-group {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px;
    border-color: rgba(37, 99, 235, 0.15);
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.02) 0%, rgba(0, 242, 254, 0.02) 100%);
  }

  .toggle-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .toggle-text strong {
    font-size: 0.95rem;
    color: var(--text-main);
  }

  .toggle-text span {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* Switch Toggle Button */
  .switch {
    position: relative;
    display: inline-block;
    width: 44px;
    height: 24px;
  }

  .switch input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: var(--border-hover);
    transition: .3s;
  }

  .slider:before {
    position: absolute;
    content: "";
    height: 18px;
    width: 18px;
    left: 3px;
    bottom: 3px;
    background-color: white;
    transition: .3s;
  }

  input:checked + .slider {
    background-color: var(--primary);
  }

  input:checked + .slider:before {
    transform: translateX(20px);
  }

  .slider.round {
    border-radius: 24px;
  }

  .slider.round:before {
    border-radius: 50%;
  }

  /* Outputs Display */
  .calc-outputs {
    position: sticky;
    top: 96px;
  }

  .outputs-container {
    padding: 24px;
    text-align: center;
    background: var(--bg-surface-solid);
    border-color: var(--border-color);
  }

  .outputs-container h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .maturity-amount-display {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 20px;
  }

  .amount-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .amount-val {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--text-main);
    letter-spacing: -0.02em;
  }

  .calc-divider {
    border: none;
    height: 1px;
    background: var(--border-color);
    margin: 20px 0;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    text-align: left;
    margin-bottom: 24px;
  }

  .metric-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .metric-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-top: 4px;
    flex-shrink: 0;
  }

  .principal-dot {
    background: var(--border-hover);
  }

  .interest-dot {
    background: var(--primary);
  }

  .metric-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    display: block;
  }

  .metric-val {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-main);
  }

  /* Donut Chart Visual */
  .chart-container {
    position: relative;
    width: 180px;
    height: 180px;
    margin: 0 auto;
  }

  .chart-bg {
    fill: none;
    stroke: var(--border-color);
  }

  .chart-fill {
    fill: none;
    stroke: var(--primary);
    stroke-linecap: round;
    transition: stroke-dashoffset 0.3s ease;
  }

  .chart-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.1;
  }

  .chart-label span:first-child {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--text-main);
  }

  .chart-label span:last-child {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* Bank Rates Section */
  .bank-rates-section {
    border-top: 1px solid var(--border-color);
    padding-top: 32px;
  }

  .bank-rates-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 4px;
    color: var(--text-main);
  }

  .bank-rates-subtitle {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .rates-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }

  @media (max-width: 1024px) {
    .rates-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .rates-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .rates-grid {
      grid-template-columns: 1fr;
    }
  }

  .bank-rate-card {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: stretch;
    text-align: center;
    border-color: var(--border-color);
  }

  .bank-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .bank-logo-placeholder {
    width: 40px;
    height: 40px;
    border-radius: 50%;
