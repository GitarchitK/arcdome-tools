---
---
<div class="resizer-tool">
  <!-- Upload Zone -->
  <div class="upload-zone glass-card" id="resize-drop-zone">
    <input type="file" id="resize-file-input" multiple accept="image/png, image/jpeg, image/webp" class="file-hidden" />
    <div class="upload-content">
      <div class="upload-icon-container">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="upload-icon">
          <rect x="2" y="2" width="20" height="20" rx="2" ry="2" />
          <path d="M7 2v20M17 2v20M2 7h20M2 17h20" />
        </svg>
      </div>
      <h3>Drag & Drop images to resize</h3>
      <p>Supports PNG, JPG, and WEBP. Scale by pixels or percentage.</p>
      <button class="btn btn-secondary" id="resize-browse-btn">Browse Files</button>
    </div>
  </div>

  <!-- Settings and Workspace -->
  <div class="tool-workspace" id="resize-workspace" style="display: none;">
    <!-- Settings Panel -->
    <div class="settings-panel glass-card">
      <div class="settings-header">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="settings-icon">
          <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" />
        </svg>
        <h3>Resizing Settings</h3>
      </div>
      
      <div class="settings-content">
        <!-- Resize Mode selector -->
        <div class="control-group">
          <label>Resize Mode</label>
          <div class="mode-toggle">
            <button class="mode-btn active" id="resize-mode-percent" type="button">Percentage</button>
            <button class="mode-btn" id="resize-mode-px" type="button">Dimensions (px)</button>
          </div>
        </div>

        <!-- Mode A: Percentage Slider -->
        <div class="control-group" id="group-resize-percent">
          <div class="label-with-value">
            <label for="resize-percent-slider">Scale Factor</label>
            <span id="resize-percent-val">50%</span>
          </div>
          <input type="range" id="resize-percent-slider" min="10" max="150" value="50" class="slider" />
          <small class="help-text">Reduce or enlarge image dimensions relative to original size.</small>
        </div>

        <!-- Mode B: Custom Pixels -->
        <div class="control-group" id="group-resize-px" style="display: none;">
          <div class="dimension-inputs">
            <div class="px-input-box">
              <label for="resize-width">Width (px)</label>
              <input type="number" id="resize-width" value="800" min="20" max="10000" />
            </div>
            <div class="px-aspect-lock">
              <button type="button" id="aspect-lock-btn" class="active" aria-label="Lock aspect ratio">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                  <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
              </button>
            </div>
            <div class="px-input-box">
              <label for="resize-height">Height (px)</label>
              <input type="number" id="resize-height" value="600" min="20" max="10000" />
            </div>
          </div>
          <small class="help-text">Dimensions will update dynamically if aspect ratio is locked.</small>
        </div>

        <!-- Format Selector -->
        <div class="control-group">
          <label for="resize-format">Save As</label>
          <select id="resize-format" class="select-dropdown">
            <option value="original" selected>Same as Original</option>
            <option value="jpeg">Convert to JPG</option>
            <option value="png">Convert to PNG</option>
            <option value="webp">Convert to WEBP</option>
          </select>
        </div>

        <button class="btn btn-primary w-full" id="resize-process-btn">Resize Images</button>
      </div>
    </div>

    <!-- Queue & Results Section -->
    <div class="queue-panel">
      <div class="queue-header">
        <h3>Queue (<span id="resize-queue-count">0</span> files)</h3>
        <div class="queue-actions">
          <button class="text-btn" id="resize-download-all-btn" style="display: none; margin-right: 12px; font-weight: 600; color: var(--primary);">Download All</button>
          <button class="text-btn" id="resize-clear-all-btn">Clear All</button>
        </div>
      </div>

      <!-- Batch Summary Box -->
      <div class="batch-summary glass-card" id="resize-batch-summary" style="display: none; padding: 12px 16px; margin-bottom: 16px; font-size: 0.85rem; border-color: rgba(34, 197, 94, 0.2); background: rgba(34, 197, 94, 0.05); border-radius: 8px;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <span style="color: var(--text-muted);">Batch Status: <strong style="color: #22c55e;">Done</strong></span>
          <span id="resize-batch-savings-text" style="font-weight: 700; color: var(--text-main);">Resized 0 files</span>
        </div>
      </div>

      <div class="queue-list" id="resize-queue-list">
        <!-- Rendered items go here -->
      </div>
    </div>
  </div>
</div>

<script>
  interface ResizeItem {
    id: string;
    file: File;
    status: 'pending' | 'resizing' | 'done' | 'failed';
    originalSize: number;
    originalWidth?: number;
    originalHeight?: number;
    targetWidth?: number;
    targetHeight?: number;
    resizedBlob?: Blob;
    outputName?: string;
  }

  let resizeQueue: ResizeItem[] = [];
  let resizeMode: 'percent' | 'px' = 'percent';
  let aspectLocked = true;

  // DOM Elements
  const dropZone = document.getElementById('resize-drop-zone') as HTMLDivElement;
  const fileInput = document.getElementById('resize-file-input') as HTMLInputElement;
  const browseBtn = document.getElementById('resize-browse-btn') as HTMLButtonElement;
  const workspace = document.getElementById('resize-workspace') as HTMLDivElement;
  const queueList = document.getElementById('resize-queue-list') as HTMLDivElement;
  const queueCount = document.getElementById('resize-queue-count') as HTMLSpanElement;
  const clearAllBtn = document.getElementById('resize-clear-all-btn') as HTMLButtonElement;
  const downloadAllBtn = document.getElementById('resize-download-all-btn') as HTMLButtonElement;
  const batchSummary = document.getElementById('resize-batch-summary') as HTMLDivElement;
  const batchSavingsText = document.getElementById('resize-batch-savings-text') as HTMLSpanElement;
  const processBtn = document.getElementById('resize-process-btn') as HTMLButtonElement;

  // Settings Elements
  const modePercent = document.getElementById('resize-mode-percent') as HTMLButtonElement;
  const modePx = document.getElementById('resize-mode-px') as HTMLButtonElement;
  const groupPercent = document.getElementById('group-resize-percent') as HTMLDivElement;
  const groupPx = document.getElementById('group-resize-px') as HTMLDivElement;
  const percentSlider = document.getElementById('resize-percent-slider') as HTMLInputElement;
  const percentVal = document.getElementById('resize-percent-val') as HTMLSpanElement;
  const widthInput = document.getElementById('resize-width') as HTMLInputElement;
  const heightInput = document.getElementById('resize-height') as HTMLInputElement;
  const aspectLockBtn = document.getElementById('aspect-lock-btn') as HTMLButtonElement;
  const formatSelect = document.getElementById('resize-format') as HTMLSelectElement;

  // Toggle Modes
  if (modePercent && modePx && groupPercent && groupPx) {
    modePercent.addEventListener('click', () => {
      resizeMode = 'percent';
      modePercent.classList.add('active');
      modePx.classList.remove('active');
      groupPercent.style.display = 'block';
      groupPx.style.display = 'none';
      updateCalculatedDimensions();
    });

    modePx.addEventListener('click', () => {
      resizeMode = 'px';
      modePx.classList.add('active');
      modePercent.classList.remove('active');
      groupPercent.style.display = 'none';
      groupPx.style.display = 'block';
      
      // Seed values with first queue item if available
      if (resizeQueue.length > 0 && resizeQueue[0].originalWidth && resizeQueue[0].originalHeight) {
        widthInput.value = String(resizeQueue[0].originalWidth);
        heightInput.value = String(resizeQueue[0].originalHeight);
      }
      updateCalculatedDimensions();
    });
  }

  // Percent Slider Value Indicator
  if (percentSlider && percentVal) {
    percentSlider.addEventListener('input', () => {
      percentVal.textContent = `${percentSlider.value}%`;
      updateCalculatedDimensions();
    });
  }

  // Aspect Lock Toggle
  if (aspectLockBtn) {
    aspectLockBtn.addEventListener('click', () => {
      aspectLocked = !aspectLocked;
      aspectLockBtn.classList.toggle('active');
      
      if (aspectLocked) {
        aspectLockBtn.querySelector('svg')!.style.color = 'var(--primary)';
        // Reset height based on current width ratio
        const first = resizeQueue[0];
        if (first && first.originalWidth && first.originalHeight) {
          const wVal = parseFloat(widthInput.value);
          const ratio = first.originalHeight / first.originalWidth;
          heightInput.value = String(Math.round(wVal * ratio));
        }
      } else {
        aspectLockBtn.querySelector('svg')!.style.color = 'var(--text-muted)';
      }
      updateCalculatedDimensions();
    });
  }

  // Linked pixel input modifications
  if (widthInput && heightInput) {
    widthInput.addEventListener('input', () => {
      if (aspectLocked && resizeQueue.length > 0) {
        const first = resizeQueue[0];
        if (first && first.originalWidth && first.originalHeight) {
          const ratio = first.originalHeight / first.originalWidth;
          const wVal = parseFloat(widthInput.value) || 0;
          heightInput.value = String(Math.round(wVal * ratio));
        }
      }
      updateCalculatedDimensions();
    });

    heightInput.addEventListener('input', () => {
      if (aspectLocked && resizeQueue.length > 0) {
        const first = resizeQueue[0];
        if (first && first.originalWidth && first.originalHeight) {
          const ratio = first.originalWidth / first.originalHeight;
          const hVal = parseFloat(heightInput.value) || 0;
          widthInput.value = String(Math.round(hVal * ratio));
        }
      }
      updateCalculatedDimensions();
    });
  }

  // Upload actions
  if (browseBtn && fileInput) {
    browseBtn.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', handleFileSelect);
  }

  if (dropZone) {
    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('drag-over');
    });

    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('drag-over');
    });

    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('drag-over');
      if (e.dataTransfer?.files) {
        processIncomingFiles(e.dataTransfer.files);
      }
    });
  }

  function handleFileSelect(e: Event) {
    const target = e.target as HTMLInputElement;
    if (target.files) {
      processIncomingFiles(target.files);
    }
  }

  async function processIncomingFiles(fileList: FileList) {
    if (downloadAllBtn) downloadAllBtn.style.display = 'none';
    if (batchSummary) batchSummary.style.display = 'none';
    for (let i = 0; i < fileList.length; i++) {
      const file = fileList[i];
      if (file.size > 15 * 1024 * 1024) {
        alert(`File "${file.name}" exceeds the 15MB limit.`);
        continue;
      }
      
      const item: ResizeItem = {
        id: `res_${Date.now()}_${Math.random().toString(36).substr(2, 5)}`,
        file: file,
        status: 'pending',
        originalSize: file.size
      };
      
      // Load image dimensions before appending
      try {
        const dimensions = await getImageDimensions(file);
        item.originalWidth = dimensions.width;
        item.originalHeight = dimensions.height;
        item.targetWidth = dimensions.width;
        item.targetHeight = dimensions.height;
      } catch (e) {
        console.error("Could not read image dimensions:", e);
      }

      resizeQueue.push(item);
    }

    // Seed Px Input boxes with first file if first addition
    if (resizeQueue.length > 0 && resizeMode === 'px' && resizeQueue[0].originalWidth) {
      widthInput.value = String(resizeQueue[0].originalWidth);
      heightInput.value = String(resizeQueue[0].originalHeight);
    }

    updateCalculatedDimensions();
    renderQueue();
    updateWorkspaceVisibility();
  }

  function getImageDimensions(file: File): Promise<{ width: number; height: number }> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => {
          resolve({ width: img.naturalWidth, height: img.naturalHeight });
        };
        img.onerror = reject;
        img.src = e.target?.result as string;
      };
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  function updateCalculatedDimensions() {
    const pct = parseInt(percentSlider.value) / 100;
    
    resizeQueue.forEach(item => {
      if (!item.originalWidth || !item.originalHeight) return;
      
      if (resizeMode === 'percent') {
        item.targetWidth = Math.round(item.originalWidth * pct);
        item.targetHeight = Math.round(item.originalHeight * pct);
      } else {
        // Pixel dimensions
        item.targetWidth = parseInt(widthInput.value) || item.originalWidth;
        item.targetHeight = parseInt(heightInput.value) || item.originalHeight;
      }
    });

    // Refresh queue UI metrics dynamically
    resizeQueue.forEach(item => {
      const row = document.getElementById(`dim_${item.id}`);
      if (row && item.targetWidth) {
        row.textContent = `Resize: ${item.targetWidth} x ${item.targetHeight} px`;
      }
    });
  }

  function formatBytes(bytes: number, decimals = 2) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ['Bytes', 'KB', 'MB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
  }

  function renderQueue() {
    if (!queueList || !queueCount) return;
    queueCount.textContent = String(resizeQueue.length);
    queueList.innerHTML = '';

    resizeQueue.forEach(item => {
      const card = document.createElement('div');
      card.className = `queue-card ${item.status}`;
      card.dataset.id = item.id;
      
      let statusIndicator = '';
      let actionBtn = '';

      if (item.status === 'pending') {
        statusIndicator = `
          <div class="result-stats">
            <span class="badge badge-pending">Ready</span>
            <span class="dim-label" id="dim_${item.id}">Resize: ${item.targetWidth} x ${item.targetHeight} px</span>
          </div>
        `;
      } else if (item.status === 'resizing') {
        statusIndicator = `
          <div class="processing-spinner">
            <svg class="spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
            </svg>
            <span>Resizing...</span>
          </div>
        `;
      } else if (item.status === 'done' && item.resizedBlob) {
        statusIndicator = `
          <div class="result-stats">
            <span class="badge badge-success">Done (${item.targetWidth}x${item.targetHeight})</span>
            <span class="comp-size">${formatBytes(item.resizedBlob.size)}</span>
          </div>
        `;
        actionBtn = `
          <button class="btn btn-primary btn-sm btn-download" data-id="${item.id}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
            Download
          </button>
        `;
      } else if (item.status === 'failed') {
        statusIndicator = `<span class="badge badge-failed">Failed</span>`;
      }

      card.innerHTML = `
        <div class="item-preview">
          <img src="" id="res_thumb_${item.id}" alt="Thumbnail" style="display: none;" />
          <div class="item-fallback-thumb" id="res_fallback_${item.id}">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
              <circle cx="8.5" cy="8.5" r="1.5" />
              <polyline points="21 15 16 10 5 21" />
            </svg>
          </div>
        </div>
        <div class="item-details">
          <div class="item-header">
            <span class="item-filename" title="${item.file.name}">${item.file.name}</span>
            <button class="item-remove" data-id="${item.id}">&times;</button>
          </div>
          <div class="item-metrics">
            <span class="orig-size">${formatBytes(item.originalSize)} (${item.originalWidth}x${item.originalHeight} px)</span>
            <div class="status-action-row">
              ${statusIndicator}
              ${actionBtn}
            </div>
          </div>
        </div>
      `;

      queueList.appendChild(card);
      
      // Load Thumbnail asynchronously
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = document.getElementById(`res_thumb_${item.id}`) as HTMLImageElement;
        const fallback = document.getElementById(`res_fallback_${item.id}`) as HTMLDivElement;
        if (img && fallback && e.target?.result) {
          img.src = e.target.result as string;
          img.style.display = 'block';
          fallback.style.display = 'none';
        }
      };
      reader.readAsDataURL(item.file);
    });

    // Wire remove buttons
    const removeBtns = queueList.querySelectorAll('.item-remove');
    removeBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = (e.currentTarget as HTMLButtonElement).dataset.id;
        resizeQueue = resizeQueue.filter(f => f.id !== id);
        renderQueue();
        updateWorkspaceVisibility();
      });
    });

    // Wire download buttons
    const downloadBtns = queueList.querySelectorAll('.btn-download');
    downloadBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = (e.currentTarget as HTMLButtonElement).dataset.id;
        const item = resizeQueue.find(f => f.id === id);
        if (item && item.resizedBlob && item.outputName) {
          downloadBlob(item.resizedBlob, item.outputName);
        }
      });
    });
  }

  function downloadBlob(blob: Blob, name: string) {
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = name;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
  }

  function updateWorkspaceVisibility() {
    if (!workspace || !dropZone) return;
    if (resizeQueue.length > 0) {
      workspace.style.display = 'grid';
      dropZone.style.padding = '24px';
      dropZone.querySelector('.upload-content h3')!.textContent = 'Add more images';
      dropZone.querySelector('.upload-content p')!.style.display = 'none';
      dropZone.querySelector('.upload-icon-container')!.style.display = 'none';
    } else {
      workspace.style.display = 'none';
      dropZone.style.padding = '48px';
      dropZone.querySelector('.upload-content h3')!.textContent = 'Drag & Drop images to resize';
      dropZone.querySelector('.upload-content p')!.style.display = 'block';
      dropZone.querySelector('.upload-icon-container')!.style.display = 'flex';
      fileInput.value = '';
      if (downloadAllBtn) downloadAllBtn.style.display = 'none';
      if (batchSummary) batchSummary.style.display = 'none';
    }
  }

  if (clearAllBtn) {
    clearAllBtn.addEventListener('click', () => {
      resizeQueue = [];
      renderQueue();
      updateWorkspaceVisibility();
    });
  }

  if (downloadAllBtn) {
    downloadAllBtn.addEventListener('click', () => {
      let delay = 0;
      resizeQueue.forEach(item => {
        if (item.status === 'done' && item.resizedBlob && item.outputName) {
          setTimeout(() => {
            downloadBlob(item.resizedBlob, item.outputName);
          }, delay);
          delay += 250;
        }
      });
    });
  }

  // Processing Loop
  if (processBtn) {
    processBtn.addEventListener('click', runBatchResizing);
  }

  async function runBatchResizing() {
    processBtn.disabled = true;
    processBtn.textContent = 'Processing...';

    const saveFormat = formatSelect.value;

    for (let i = 0; i < resizeQueue.length; i++) {
      const item = resizeQueue[i];
      if (item.status === 'done' || !item.targetWidth || !item.targetHeight) continue;
      
      item.status = 'resizing';
      renderQueue();

      try {
        const result = await resizeSingleImage(item.file, item.targetWidth, item.targetHeight, saveFormat);

        item.status = 'done';
        item.resizedBlob = result.blob;
        
        const originalNameParts = item.file.name.split('.');
        originalNameParts.pop();
        const baseName = originalNameParts.join('.');
        item.outputName = `${baseName}_resized.${result.ext}`;
      } catch (err) {
        console.error(err);
        item.status = 'failed';
      }

      renderQueue();
    }

    processBtn.disabled = false;
    processBtn.textContent = 'Resize Images';

    // Calculate total batch stats for resizing
    let successCount = 0;
    let totalOrig = 0;
    let totalResized = 0;
    resizeQueue.forEach(item => {
      if (item.status === 'done' && item.resizedBlob) {
        totalOrig += item.originalSize;
        totalResized += item.resizedBlob.size;
        successCount++;
      }
    });

    if (successCount > 0 && downloadAllBtn && batchSummary && batchSavingsText) {
      downloadAllBtn.style.display = 'inline-block';
      batchSummary.style.display = 'block';
      const savedBytes = totalOrig - totalResized;
      if (savedBytes > 0) {
        const savedPct = Math.round((savedBytes / totalOrig) * 100);
        batchSavingsText.innerHTML = `Resized ${successCount} files. Saved ${formatBytes(savedBytes)} (${savedPct}%)`;
      } else {
        batchSavingsText.innerHTML = `Resized ${successCount} files successfully!`;
      }
    }
  }

  function loadImageElement(file: File): Promise<HTMLImageElement> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => resolve(img);
        img.onerror = (err) => reject(err);
        img.src = e.target?.result as string;
      };
      reader.onerror = (err) => reject(err);
      reader.readAsDataURL(file);
    });
  }

  interface ResizeResult {
    blob: Blob;
    ext: string;
  }

  async function resizeSingleImage(
    file: File, 
    width: number, 
    height: number, 
    format: string
  ): Promise<ResizeResult> {
    const img = await loadImageElement(file);
    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d');

    if (!ctx) throw new Error('Could not get Canvas Context');

    // Set resized dimensions
    canvas.width = width;
    canvas.height = height;
    
    // Draw with smooth scaling (optional: can configure imageSmoothingEnabled)
    ctx.imageSmoothingEnabled = true;
    ctx.imageSmoothingQuality = 'high';
    ctx.drawImage(img, 0, 0, width, height);

    let mimeType = file.type;
    let ext = file.name.split('.').pop() || 'jpg';

    if (format === 'jpeg') {
      mimeType = 'image/jpeg';
      ext = 'jpg';
    } else if (format === 'png') {
      mimeType = 'image/png';
      ext = 'png';
    } else if (format === 'webp') {
      mimeType = 'image/webp';
      ext = 'webp';
    }

    const blob: Blob = await new Promise((resolve, reject) => {
      try {
        canvas.toBlob((b) => {
          if (b) resolve(b);
          else reject(new Error('Canvas returned null blob'));
        }, mimeType, 0.90); // Use 90% quality for rescaled exports
      } catch (e) {
        reject(e);
      }
    }) as Blob;

    return { blob, ext };
  }
</script>

<style>
  /* Reuse design rules from ImageCompressor */
  .resizer-tool {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Drop Zone */
  .upload-zone {
    padding: 48px;
    text-align: center;
    border: 2px dashed var(--border-color);
    cursor: pointer;
    background: rgba(255, 255, 255, 0.55);
    display: flex;
    justify-content: center;
    align-items: center;
    transition: var(--transition-smooth);
    min-height: 200px;
  }

  .upload-zone:hover, .upload-zone.drag-over {
    border-color: var(--primary);
