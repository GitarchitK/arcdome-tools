---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-grid">
      <!-- About / Brand Info -->
      <div class="footer-info">
        <a href="/" class="footer-logo">
          <span class="logo-text">Arc<span class="gradient-text-alt">dome</span></span>
        </a>
        <p class="footer-desc">
          Professional, client-side browser image tools. Compress, resize, and convert images locally. Your files never touch a remote server, ensuring 100% security and privacy.
        </p>
      </div>

      <!-- Quick Links: Tools -->
      <div class="footer-links-group">
        <h4 class="footer-title">Image Tools</h4>
        <ul class="footer-links">
          <li><a href="/compress-image">Compress Image Online</a></li>
          <li><a href="/convert-image">Convert Image Format</a></li>
          <li><a href="/resize-image">Resize Image Pixels</a></li>
        </ul>
      </div>

      <!-- Quick Links: Information -->
      <div class="footer-links-group">
        <h4 class="footer-title">Company</h4>
        <ul class="footer-links">
          <li><a href="/about">About Arcdome</a></li>
          <li><a href="/blog">Knowledge Blog</a></li>
          <li><a href="/contact">Contact Support</a></li>
        </ul>
      </div>

      <!-- Quick Links: Legal -->
      <div class="footer-links-group">
        <h4 class="footer-title">Legal & Security</h4>
        <ul class="footer-links">
          <li><a href="/privacy-policy">Privacy Policy</a></li>
          <li><a href="/terms-of-service">Terms of Service</a></li>
        </ul>
      </div>

      <!-- Quick Links: Sitemap -->
      <div class="footer-links-group">
        <h4 class="footer-title">Sitemaps</h4>
        <ul class="footer-links">
          <li><a href="/sitemap">HTML Sitemap Directory</a></li>
          <li><a href="/sitemap.xml" target="_blank">XML Sitemap Index</a></li>
        </ul>
      </div>
    </div>

    <!-- Charity Donation & Bottom Bar -->
    <hr class="footer-divider" />
    
    <div class="footer-bottom">
      <p class="copyright">&copy; {currentYear} Arcdome. All rights reserved.</p>
      <p class="charity-note">
        Developed by Archit. 100% of all proceeds generated from this platform are donated directly to charitable causes.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-footer);
    border-top: 1px solid var(--border-color);
    padding: 64px 0 32px;
    margin-top: auto;
    font-size: 0.9rem;
  }

  .footer-container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2.5fr 1.5fr 1fr 1fr 1fr;
    gap: 32px;
    margin-bottom: 48px;
  }

  @media (max-width: 990px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    
    .footer-info {
      grid-column: span 2;
    }
  }

  @media (max-width: 500px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    
    .footer-info {
      grid-column: span 1;
    }
  }

  .footer-logo {
    display: inline-block;
    margin-bottom: 16px;
    text-decoration: none;
  }

  .logo-text {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-main);
    letter-spacing: -0.02em;
  }

  .gradient-text-alt {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .footer-desc {
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 320px;
  }

  .footer-links-group {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer-title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-main);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-links {
    list-style-type: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-links a {
    color: var(--text-muted);
    text-decoration: none;
    transition: var(--transition-smooth);
  }

  .footer-links a:hover {
    color: var(--primary);
    padding-left: 4px;
  }

  /* Divider & Bottom bar */
  .footer-divider {
    border: none;
    height: 1px;
    background: var(--border-color);
    margin-bottom: 24px;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .copyright {
    color: var(--text-muted);
  }

  .charity-note {
    max-width: 500px;
    text-align: right;
    line-height: 1.4;
    color: var(--text-muted);
  }

  @media (max-width: 820px) {
    .footer-bottom {
      flex-direction: column;
      text-align: center;
      align-items: center;
    }
    
    .charity-note {
      text-align: center;
    }
  }
</style>
