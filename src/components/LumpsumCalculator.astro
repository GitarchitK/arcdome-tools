---
// Lump Sum Investment Calculator
---

<div class="calculator-card glass-card">
  <div class="calculator-layout">
    <!-- Inputs Panel -->
    <div class="calc-inputs">
      <h2 class="calc-title">Lump Sum Investment Calculator</h2>
      <p class="calc-subtitle">Estimate the growth of a one-time lumpsum mutual fund or equity investment compounded annually.</p>

      <!-- Total Deposit / Lumpsum -->
      <div class="input-group">
        <div class="input-header">
          <label for="lump-total">One-Time Investment (₹)</label>
          <input type="number" id="lump-total-num" min="10000" max="10000000" step="10000" value="100000" class="num-input font-semibold" />
        </div>
        <input type="range" id="lump-total" min="10000" max="10000000" step="10000" value="100000" class="range-slider" />
        <div class="slider-labels">
          <span>₹10K</span>
          <span>₹50L</span>
          <span>₹1Cr (Max Limit)</span>
        </div>
      </div>

      <!-- Expected Return Rate -->
      <div class="input-group">
        <div class="input-header">
          <label for="lump-rate">Expected Return Rate (% p.a.)</label>
          <input type="number" id="lump-rate-num" min="1" max="30" step="0.5" value="12" class="num-input" />
        </div>
        <input type="range" id="lump-rate" min="1" max="30" step="0.5" value="12" class="range-slider" />
        <div class="slider-labels">
          <span>1%</span>
          <span>15%</span>
          <span>30%</span>
        </div>
      </div>

      <!-- Return Presets -->
      <div class="presets-group">
        <span class="presets-label">Investment Presets:</span>
        <div class="presets-buttons">
          <button class="lump-preset-btn" data-rate="18">Small Cap (~18%)</button>
          <button class="lump-preset-btn" data-rate="15">Mid Cap (~15%)</button>
          <button class="lump-preset-btn active" data-rate="12">Large Cap (~12%)</button>
          <button class="lump-preset-btn" data-rate="7">FD / Debt (~7%)</button>
        </div>
      </div>

      <!-- Time Period -->
      <div class="input-group">
        <div class="input-header">
          <label for="lump-years">Investment Period (Years)</label>
          <input type="number" id="lump-years-num" min="1" max="40" step="1" value="10" class="num-input" />
        </div>
        <input type="range" id="lump-years" min="1" max="40" step="1" value="10" class="range-slider" />
        <div class="slider-labels">
          <span>1 Yr</span>
          <span>20 Yrs</span>
          <span>40 Yrs</span>
        </div>
      </div>
    </div>

    <!-- Outputs & Charts Panel -->
    <div class="calc-outputs">
      <div class="outputs-container glass-card">
        <h3>Estimated Wealth</h3>

        <!-- Payout Displays -->
        <div class="payout-row">
          <div class="payout-box highlighted-payout">
            <span class="payout-label">Future Value (Maturity)</span>
            <span class="payout-val" id="lump-future-val">₹3.11L</span>
          </div>
        </div>

        <hr class="calc-divider" />

        <!-- Metrics Grid -->
        <div class="metrics-grid">
          <div class="metric-item">
            <span class="metric-dot principal-dot"></span>
            <div>
              <span class="metric-label">Invested Capital</span>
              <span class="metric-val" id="lump-invested-val">₹1,00,000</span>
            </div>
          </div>
          <div class="metric-item">
            <span class="metric-dot interest-dot"></span>
            <div>
              <span class="metric-label">Wealth Gained</span>
              <span class="metric-val text-primary" id="lump-gained-val">₹2,10,585</span>
            </div>
          </div>
        </div>

        <hr class="calc-divider" style="margin-top: 0;" />

        <!-- SVG Donut Chart Visual -->
        <div class="chart-container">
          <svg width="180" height="180" viewBox="0 0 180 180" class="donut-chart">
            <circle cx="90" cy="90" r="70" class="chart-bg" stroke-width="16" />
            <circle cx="90" cy="90" r="70" class="chart-fill" id="lump-chart-fill" stroke-width="16" stroke-dasharray="439.8" stroke-dashoffset="210" transform="rotate(-90 90 90)" />
          </svg>
          <div class="chart-label">
            <span id="lump-ratio-pct">67.8%</span>
            <span>Est. Gain</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Elements
  const totalSlider = document.getElementById('lump-total') as HTMLInputElement;
  const totalNum = document.getElementById('lump-total-num') as HTMLInputElement;
  const rateSlider = document.getElementById('lump-rate') as HTMLInputElement;
  const rateNum = document.getElementById('lump-rate-num') as HTMLInputElement;
  const yearsSlider = document.getElementById('lump-years') as HTMLInputElement;
  const yearsNum = document.getElementById('lump-years-num') as HTMLInputElement;
  const presetBtns = document.querySelectorAll('.presets-buttons .lump-preset-btn');

  const futureValText = document.getElementById('lump-future-val');
  const investedValText = document.getElementById('lump-invested-val');
  const gainedValText = document.getElementById('lump-gained-val');
  const ratioText = document.getElementById('lump-ratio-pct');
  const chartFillCircle = document.getElementById('lump-chart-fill');

  // Synchronizers
  function syncInputs(slider: HTMLInputElement, numInput: HTMLInputElement, callback: () => void) {
    slider.addEventListener('input', () => {
      numInput.value = slider.value;
      callback();
    });
    numInput.addEventListener('change', () => {
      let val = parseFloat(numInput.value);
      const min = parseFloat(numInput.min);
      const max = parseFloat(numInput.max);
      if (isNaN(val)) val = min;
      if (val < min) val = min;
      if (val > max) val = max;
      numInput.value = String(val);
      slider.value = String(val);
      callback();
    });
  }

  // Calculate Lumpsum Compound Value
  function calculateLumpsum() {
    const P = parseFloat(totalSlider.value);
    const R = parseFloat(rateSlider.value);
    const years = parseFloat(yearsSlider.value);

    // Formula: M = P * (1 + R/100)^t
    const futureValue = P * Math.pow(1 + (R / 100), years);
    const wealthGained = futureValue - P;

    // Currency Formatting (Indian Lakhs / Crores if large)
    const formatCurrency = (val: number) => {
      if (val >= 10000000) {
        return '₹' + (val / 10000000).toFixed(2) + ' Cr';
      } else if (val >= 100000) {
        return '₹' + (val / 100000).toFixed(2) + ' L';
      }
      return '₹' + Math.round(val).toLocaleString('en-IN');
    };

    const formatCurrencyFull = (val: number) => {
      return '₹' + Math.round(val).toLocaleString('en-IN');
    };

    // Update Text
    if (futureValText) futureValText.innerText = formatCurrency(futureValue);
    if (investedValText) investedValText.innerText = formatCurrencyFull(P);
    if (gainedValText) gainedValText.innerText = formatCurrencyFull(wealthGained > 0 ? wealthGained : 0);

    // Donut Chart updates
    const totalCash = futureValue;
    const ratio = totalCash > 0 ? (wealthGained / totalCash) : 0;
    const gainPct = ratio * 100;
    
    if (ratioText) ratioText.innerText = gainPct.toFixed(1) + '%';

    if (chartFillCircle) {
      const maxOffset = 439.8;
      const offset = maxOffset - (gainPct / 100) * maxOffset;
      chartFillCircle.setAttribute('stroke-dashoffset', String(offset));
    }
  }

  // Preset Rate Buttons
  presetBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      presetBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const rate = btn.getAttribute('data-rate');
      if (rate) {
        rateSlider.value = rate;
        rateNum.value = rate;
        calculateLumpsum();
      }
    });
  });

  // Init
  syncInputs(totalSlider, totalNum, calculateLumpsum);
  syncInputs(rateSlider, rateNum, () => {
    presetBtns.forEach(b => {
      const r = b.getAttribute('data-rate');
      if (r === rateSlider.value) {
        b.classList.add('active');
      } else {
        b.classList.remove('active');
      }
    });
    calculateLumpsum();
  });
  syncInputs(yearsSlider, yearsNum, calculateLumpsum);

  calculateLumpsum();
</script>

<style>
  /* Base Styles matching other calculators */
  .calculator-card {
    padding: 32px;
    background: var(--bg-surface);
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .calculator-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 32px;
    align-items: start;
  }

  @media (max-width: 820px) {
    .calculator-layout {
      grid-template-columns: 1fr;
    }
    .calculator-card {
      padding: 20px;
    }
  }

  .calc-title {
    font-size: 1.85rem;
    font-weight: 800;
    margin-bottom: 8px;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .calc-subtitle {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .calc-inputs {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .input-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .input-header label {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-main);
  }

  .num-input {
    width: 110px;
    background: var(--bg-base);
    border: 1px solid var(--border-color);
    color: var(--text-main);
    padding: 6px 12px;
    border-radius: 6px;
    font-weight: 600;
    text-align: right;
    font-family: var(--font-body);
  }

  .num-input:focus {
    outline: none;
    border-color: var(--primary);
  }

  .range-slider {
    width: 100%;
    height: 6px;
    background: var(--border-color);
    border-radius: 3px;
    outline: none;
    -webkit-appearance: none;
    cursor: pointer;
  }

  .range-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--primary);
    box-shadow: 0 0 8px rgba(37, 99, 235, 0.4);
    transition: transform 0.1s ease;
  }

  .range-slider::-webkit-slider-thumb:hover {
    transform: scale(1.15);
  }

  .slider-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: -2px;
  }

  /* Preset Buttons styling */
  .presets-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: -4px;
  }

  .presets-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .presets-buttons {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .lump-preset-btn {
    font-size: 0.8rem;
    padding: 6px 12px;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    background: var(--bg-btn-sec);
    color: var(--text-main);
    cursor: pointer;
    font-weight: 500;
    transition: var(--transition-smooth);
  }

  .lump-preset-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
    background: var(--primary-glow);
  }

  .lump-preset-btn.active {
    background: var(--primary);
    border-color: var(--primary);
    color: #ffffff;
  }

  /* Outputs Panel */
  .calc-outputs {
    position: sticky;
    top: 96px;
  }

  .outputs-container {
    padding: 24px;
    text-align: center;
    background: var(--bg-surface-solid);
    border-color: var(--border-color);
  }

  .outputs-container h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .payout-box {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .highlighted-payout {
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.06) 0%, rgba(0, 242, 254, 0.06) 100%);
    border: 1px dashed rgba(37, 99, 235, 0.3);
    padding: 16px;
    border-radius: 8px;
  }

  .payout-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  .payout-val {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--primary);
    letter-spacing: -0.02em;
  }

  .calc-divider {
    border: none;
    height: 1px;
    background: var(--border-color);
    margin: 20px 0;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    text-align: left;
    margin-bottom: 20px;
  }

  .metric-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .metric-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-top: 4px;
    flex-shrink: 0;
  }

  .principal-dot {
    background: var(--border-hover);
  }

  .interest-dot {
    background: var(--primary);
  }

  .metric-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    display: block;
  }

  .metric-val {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-main);
  }

  /* Donut Chart Visual */
  .chart-container {
    position: relative;
    width: 180px;
    height: 180px;
    margin: 0 auto;
  }

  .chart-bg {
    fill: none;
    stroke: var(--border-color);
  }

  .chart-fill {
    fill: none;
    stroke: var(--primary);
    stroke-linecap: round;
    transition: stroke-dashoffset 0.3s ease;
  }

  .chart-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.1;
  }

  .chart-label span:first-child {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--text-main);
  }

  .chart-label span:last-child {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
  }
</style>
